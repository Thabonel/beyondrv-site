---
import BaseLayout from '../../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Privacy Policy | Beyond RV",
  "url": "https://beyondrv.com.au/privacy-policy/"
};
---
<BaseLayout
  title="Privacy Policy | Beyond RV"
  description="Beyond RV privacy policy — how we collect, use, and protect your personal information in accordance with the Australian Privacy Principles."
  activePath="/privacy-policy/"
  structuredData={schema}
>
  <section class="page-hero page-hero--short">
    <div class="hero-overlay" style="background: rgba(10,10,10,0.425)"></div>
    <div class="page-hero-content">
      <div class="section-eyebrow">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-text">Legal</span>
      </div>
      <h1 class="hero-title">Privacy Policy</h1>
    </div>
  </section>

  <section class="container">
    <div class="page-content">
      <p style="font-size: 0.82rem; color: var(--muted); border-left: 2px solid var(--orange); padding-left: 1rem; margin-bottom: 2rem">
        Last updated: May 2026. This policy applies to beyondrv.com.au.
      </p>

      <h2>About This Policy</h2>
      <p>
        Beyond RV ("we", "us", "our") is committed to protecting your personal information in accordance with the
        <strong>Australian Privacy Principles (APPs)</strong> set out in the <em>Privacy Act 1988</em> (Cth).
        This policy explains what personal information we collect, how we use it, and who we share it with.
      </p>

      <h2>What Information We Collect</h2>
      <h3>Enquiry form submissions</h3>
      <p>
        When you submit an enquiry via our website, we collect your name, email address, phone number,
        message content, preferred call-back date and time, and any product interest you indicate. This is the primary
        information we use to respond to you.
      </p>

      <h3>Website analytics</h3>
      <p>
        We use <strong>PostHog</strong> (posthog.com) to collect anonymised analytics data about how visitors
        use this website — including pages visited, time spent, and general geographic region. This data does
        not personally identify you. PostHog analytics are only loaded after you consent via our cookie banner.
      </p>

      <h3>Chatbot conversations</h3>
      <p>
        Our website includes a customer-facing chat assistant. Conversations with the assistant are processed
        by <strong>OpenAI</strong> (openai.com). We may record chatbot questions, assistant responses, page context,
        product context, and broad topic categories in PostHog so we can understand what customers are asking,
        improve our product information, and identify when customers need human follow-up. Obvious email addresses
        and phone numbers are redacted before analytics storage where possible.
      </p>

      <h2>How We Use Your Information</h2>
      <p>We use the information you provide to:</p>
      <ul>
        <li>Respond to your enquiry and contact you at your requested call-back time</li>
        <li>Understand which products you're interested in so we can assist you effectively</li>
        <li>Review chatbot questions and common topics so we can improve product information and customer support</li>
        <li>Improve our website and products based on aggregated, anonymised analytics</li>
      </ul>
      <p>
        We do not use your personal information for marketing purposes without your explicit consent.
        Submitting an enquiry implies consent for us to contact you in response to that enquiry only.
      </p>

      <h2>Third Parties We Share Data With</h2>
      <ul>
        <li><strong>Netlify</strong> (netlify.com) — our website host. Netlify stores and processes enquiry form submissions on our behalf. See Netlify's privacy policy for details.</li>
        <li><strong>Resend</strong> (resend.com) — email delivery provider for sending enquiry notifications to the Beyond RV team.</li>
        <li><strong>PostHog</strong> (posthog.com) — analytics and chatbot question reporting. Browser analytics only load with your consent; chatbot question reporting is used as an operational support tool.</li>
        <li><strong>OpenAI</strong> (openai.com) — processes chat assistant conversations in real time.</li>
        <li><strong>Google Fonts</strong> — loads font files from Google's servers. Google may log font requests.</li>
      </ul>
      <p>We do not sell your personal information to any third party.</p>

      <h2>Cookies</h2>
      <p>
        We use a cookie consent banner on your first visit. If you accept analytics cookies, PostHog will set
        cookies to enable usage tracking. If you decline, PostHog is not loaded and no analytics cookies are set.
        The enquiry form and chat assistant function regardless of your cookie choice.
      </p>

      <h2>Your Rights</h2>
      <p>Under the Australian Privacy Principles, you have the right to:</p>
      <ul>
        <li>Request access to the personal information we hold about you</li>
        <li>Request correction of inaccurate or incomplete information</li>
        <li>Request deletion of your personal information (subject to legal obligations)</li>
        <li>Lodge a complaint about how we handle your personal information</li>
      </ul>

      <h2>Contact for Privacy Queries</h2>
      <p>
        For any privacy-related requests or complaints, contact us at:<br />
        <strong>Email:</strong> <a href="mailto:beyondcaravans@gmail.com">beyondcaravans@gmail.com</a><br />
        <strong>Post:</strong> 77 Coleyville Rd, Mutdapilly QLD 4307
      </p>
      <p>
        If you're not satisfied with our response, you may contact the
        <a href="https://www.oaic.gov.au" target="_blank" rel="noopener">Office of the Australian Information Commissioner (OAIC)</a>.
      </p>

      <p style="margin-top: 3rem; font-size: 0.8rem; color: var(--muted)">
        Beyond RV may update this privacy policy from time to time. Changes will be posted on this page
        with an updated date.
      </p>
    </div>
  </section>
</BaseLayout>
