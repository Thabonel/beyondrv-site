---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { displayImageUrl } from '../../lib/media';

const products = (await getCollection('products'))
  .filter(p => p.data.category === 'caravan')
  .sort((a, b) => (a.data.status === 'coming-soon' ? 1 : 0) - (b.data.status === 'coming-soon' ? 1 : 0));

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Beyond RV Off-Road Caravans",
  "url": "https://beyondrv.com.au/our-caravans/",
  "hasPart": products.map(p => ({
    "@type": "Product",
    "name": p.data.title,
    "url": `https://beyondrv.com.au/${p.slug}/`
  }))
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Are Beyond RV caravans built for off-road touring?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Beyond RV focuses on composite off-road caravans for Australian touring, with layouts for couples and families depending on the model."
      }
    },
    {
      "@type": "Question",
      "name": "How do I choose between a couples caravan and a family caravan?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Couples models prioritise compact towing, storage, and self-contained comfort. Family models add sleeping capacity and living space for longer trips with children."
      }
    }
  ]
};
const heroImage = '/images/optimized/products/sunpatch-15xc-couples-offroad-van/01-beyond-rv-sunpatch-15-xc-01-768x509.webp';
const ctaImage = '/images/optimized/products/sunpatch-15xc-couples-offroad-van/16-beyond-rv-sunpatch-15-xc-02-768x509.webp';
---
<BaseLayout
  title="Off-Road Caravans | Beyond RV Queensland"
  description="Beyond RV builds composite off-road caravans for couples and families. The Sunpatch range — built in Queensland for serious Australian travel."
  image={heroImage}
  activePath="/our-caravans/"
  structuredData={[schema, faqSchema]}
>
  <section class="page-hero">
    <div class="page-hero-bg" style={`background-image: url('${displayImageUrl(heroImage, 1600)}')`}></div>
    <div class="hero-overlay"></div>
    <div class="hero-overlay-bottom"></div>
    <div class="page-hero-content">
      <div class="section-eyebrow">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-text">Off-Road Caravans</span>
      </div>
      <h1 class="hero-title">Our Caravans</h1>
      <p class="hero-sub">
        Queensland-built off-road caravans for couples and families who refuse to stay on the beaten track.
        Full composite construction. Independent suspension. Built to go where you want to go.
      </p>
    </div>
  </section>

  <section class="category-grid container">
    <div class="product-grid">
      {products.map(p => (
        <ProductCard
          title={p.data.title}
          slug={p.slug}
          category={p.data.category}
          tagline={p.data.tagline}
          price={p.data.price}
          status={p.data.status}
          heroImage={p.data.heroImage}
          priceBadge={p.data.priceBadge}
        />
      ))}
    </div>
  </section>

  <section class="container" style="padding-bottom: 5rem">
    <div class="page-content">
      <h2>Off-road caravans for couples and families</h2>
      <h3>What makes a caravan suitable for remote touring?</h3>
      <p>
        Look at construction, suspension, water capacity, electrical capacity, storage, and real-world towing
        weight. Beyond RV focuses on practical off-road caravan layouts that can handle Australian travel rather
        than only looking good in a showroom.
      </p>
      <h3>Couples or family layout?</h3>
      <p>
        Couples caravans suit buyers who want a compact, self-contained van with less towing weight. Family
        caravans prioritise extra sleeping space, storage, and a layout that works when the weather turns.
      </p>
      <p>
        Compare the current range above, or <a href="/inquiry-form/">ask the team</a> which caravan best
        suits your tow vehicle and travel plans.
      </p>
    </div>
  </section>

  <section class="cta-section" style="padding: 7rem var(--gutter)">
    <div class="cta-bg" style={`background-image: url('${displayImageUrl(ctaImage, 1600)}')`}></div>
    <div class="cta-overlay"></div>
    <div class="cta-content">
      <h2 class="cta-title reveal">Not sure <span class="italic">which one?</span></h2>
      <p class="cta-sub reveal reveal-delay-1">Tell us how you travel and we'll point you in the right direction.</p>
      <div class="cta-actions reveal reveal-delay-2">
        <a href="/inquiry-form/" class="btn-primary">Talk to the Team</a>
        <a href="tel:+61430863819" class="btn-ghost">Call 0430 863 819</a>
      </div>
    </div>
  </section>
</BaseLayout>
