---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';

const allProducts = await getCollection('products');
const featuredProducts = allProducts.filter(p => p.data.featured).slice(0, 4);

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Beyond RV",
  "url": "https://beyondrv.com.au",
  "logo": "https://beyondrv.com.au/images/site/logo.jpg",
  "telephone": "+61430863819",
  "email": "beyondcaravans@gmail.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "77 Coleyville Rd",
    "addressLocality": "Mutdapilly",
    "addressRegion": "QLD",
    "postalCode": "4307",
    "addressCountry": "AU"
  }
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Beyond RV",
  "url": "https://beyondrv.com.au",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://beyondrv.com.au/our-slide-on-campers/?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
};
---
<BaseLayout
  title="Beyond RV — Queensland Slide-On Campers, Caravans & Expedition Vehicles"
  description="Beyond RV builds slide-on campers, hardtop caravans, and expedition vehicles in Mutdapilly, Queensland. For HiLux, Ranger, Unimog, and serious trucks. ADR compliant."
  structuredData={[orgSchema, websiteSchema]}
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg" style="background-image: url('/images/site/unimog-hero.jpg')"></div>
    <div class="hero-overlay"></div>
    <div class="hero-overlay-bottom"></div>

    <div class="hero-content">
      <div class="hero-eyebrow">
        <div class="hero-eyebrow-line"></div>
        <span class="hero-eyebrow-text">Queensland's Slide-On Specialists</span>
      </div>
      <h1 class="hero-title">
        Built For<br>
        <span class="italic">Where</span><br>
        <span class="accent">Roads End</span>
      </h1>
      <p class="hero-sub">
        Slide-on campers engineered in Queensland for Unimogs, Ivecos, Isuzu trucks and serious utes.
        Weeks of Australian craftsmanship. Zero compromises.
      </p>
      <div class="hero-actions">
        <a href="/our-slide-on-campers/" class="btn-primary">Explore the Range</a>
        <a href="/inquiry-form/" class="btn-ghost">Get a Build Quote</a>
      </div>
    </div>

    <div class="hero-stats">
      <div class="hero-stat">
        <div class="hero-stat-num">10<span>+</span></div>
        <div class="hero-stat-label">Years Experience</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">100<span>%</span></div>
        <div class="hero-stat-label">Queensland Finished</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">4<span>x</span></div>
        <div class="hero-stat-label">Vehicle Classes</div>
      </div>
    </div>

    <div class="hero-scroll" aria-hidden="true">
      <div class="hero-scroll-line"></div>
      <div class="hero-scroll-text">Scroll</div>
    </div>
  </section>

  <!-- TICKER -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker-track">
      <span class="ticker-item">Caravans</span>
      <span class="ticker-item ticker-dot">✦</span>
      <span class="ticker-item">Slide-On Campers</span>
      <span class="ticker-item ticker-dot">✦</span>
      <span class="ticker-item">Unimog Builds</span>
      <span class="ticker-item ticker-dot">✦</span>
      <span class="ticker-item">Iveco Daily</span>
      <span class="ticker-item ticker-dot">✦</span>
      <span class="ticker-item">Isuzu NPR</span>
      <span class="ticker-item ticker-dot">✦</span>
      <span class="ticker-item">Custom Ute Campers</span>
      <span class="ticker-item ticker-dot">✦</span>
      <span class="ticker-item">Queensland Finished</span>
      <span class="ticker-item ticker-dot">✦</span>
      <span class="ticker-item">Expedition Ready</span>
      <span class="ticker-item ticker-dot">✦</span>
      <!-- Duplicate for seamless loop -->
      <span class="ticker-item">Caravans</span>
      <span class="ticker-item ticker-dot">✦</span>
      <span class="ticker-item">Slide-On Campers</span>
      <span class="ticker-item ticker-dot">✦</span>
      <span class="ticker-item">Unimog Builds</span>
      <span class="ticker-item ticker-dot">✦</span>
      <span class="ticker-item">Iveco Daily</span>
      <span class="ticker-item ticker-dot">✦</span>
      <span class="ticker-item">Isuzu NPR</span>
      <span class="ticker-item ticker-dot">✦</span>
      <span class="ticker-item">Custom Ute Campers</span>
      <span class="ticker-item ticker-dot">✦</span>
      <span class="ticker-item">Queensland Finished</span>
      <span class="ticker-item ticker-dot">✦</span>
      <span class="ticker-item">Expedition Ready</span>
      <span class="ticker-item ticker-dot">✦</span>
    </div>
  </div>

  <!-- RANGE OVERVIEW (3-card category grid) -->
  <section class="range">
    <div class="range-header">
      <div>
        <div class="section-eyebrow reveal">
          <div class="section-eyebrow-line"></div>
          <span class="section-eyebrow-text">Our Range</span>
        </div>
        <h2 class="section-title reveal reveal-delay-1">Three Ranges.<br>One Standard.</h2>
      </div>
      <a href="/our-slide-on-campers/" class="btn-ghost reveal reveal-delay-2">View All Models →</a>
    </div>

    <div class="range-grid">
      <div class="model-card featured reveal">
        <img src="/images/site/unimog-hero.jpg" alt="Beyond RV Expedition Vehicles — Unimog builds" style="object-position: center 40%" />
        <div class="model-card-overlay"></div>
        <div class="model-card-content">
          <span class="model-tag">Expedition</span>
          <div class="model-name">Expedition Vehicles</div>
          <div class="model-spec">Unimog · Isuzu NPS · Custom builds for where roads end</div>
          <a href="/expedition/" class="model-link">Explore Expedition →</a>
        </div>
      </div>

      <div class="model-card featured reveal">
        <img src="/images/products/advent-2150/advent-2150-01.jpg" alt="Beyond RV Slide-On Campers — Advent range" style="object-position: center 55%" />
        <div class="model-card-overlay"></div>
        <div class="model-card-content">
          <span class="model-tag">Slide-Ons</span>
          <div class="model-name">Slide-On Campers</div>
          <div class="model-spec">Advent 2150 · 2300 · 2450 · Pop-tops · Truck campers</div>
          <a href="/our-slide-on-campers/" class="model-link">Explore Slide-Ons →</a>
        </div>
      </div>

      <div class="model-card reveal reveal-delay-1">
        <img src="/images/products/sunpatch-15xc/sunpatch-15xc-01.jpg" alt="Beyond RV Sunpatch caravans" />
        <div class="model-card-overlay"></div>
        <div class="model-card-content">
          <span class="model-tag">Caravans</span>
          <div class="model-name">Our Caravans</div>
          <div class="model-spec">Sunpatch 15-XC · Off-road couples & family vans</div>
          <a href="/our-caravans/" class="model-link">Explore Caravans →</a>
        </div>
      </div>

      <div class="model-card reveal reveal-delay-2">
        <img src="/images/products/advent-2150/advent-2150-04.jpg" alt="Beyond RV interior fit-out" />
        <div class="model-card-overlay"></div>
        <div class="model-card-content">
          <span class="model-tag">Custom</span>
          <div class="model-name">Custom Builds</div>
          <div class="model-spec">Any truck · Any spec · Built to order in Queensland</div>
          <a href="/custom/" class="model-link">Start a Custom Build →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED PRODUCTS -->
  {featuredProducts.length > 0 && (
    <section style="background: var(--dark); border-top: 1px solid var(--border); padding: 7rem var(--gutter)">
      <div class="section-eyebrow reveal">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-text">Featured</span>
      </div>
      <h2 class="section-title reveal reveal-delay-1">Ready to Roll</h2>
      <div class="product-grid" style="margin-top: 3rem">
        {featuredProducts.map(p => (
          <ProductCard
            title={p.data.title}
            slug={p.slug}
            category={p.data.category}
            tagline={p.data.tagline}
            price={p.data.price}
            status={p.data.status}
            heroImage={p.data.heroImage}
            priceBadge={p.data.priceBadge}
          />
        ))}
      </div>
    </section>
  )}

  <!-- STORY / WHY BEYONDRV -->
  <section class="story">
    <div class="story-image">
      <img src="/images/site/mog2.jpg" alt="Beyond RV Unimog expedition build — Mutdapilly Queensland workshop" />
      <div class="story-image-overlay"></div>
    </div>
    <div class="story-content">
      <div class="section-eyebrow reveal">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-text">How We Build It</span>
      </div>
      <h2 class="section-title reveal reveal-delay-1">Engineered<br>in Queensland</h2>
      <p style="font-size:0.95rem; color:var(--muted); line-height:1.8; margin-top:1.5rem" class="reveal reveal-delay-2">
        Imported where it makes sense. Finished, fitted, certified, supported and warrantied in Queensland.
        Every circuit wired by hand. Every fitting measured. Every detail checked before it leaves our floor.
      </p>
      <p style="font-size:0.95rem; color:var(--muted); line-height:1.8; margin-top:1rem" class="reveal reveal-delay-3">
        The result: expedition-grade quality built to Australian standards and ADR compliance,
        at a price that reflects smart manufacturing — not corners cut.
      </p>
      <div class="story-numbers reveal reveal-delay-3">
        <div class="story-num">
          <div class="story-num-val">3–6</div>
          <div class="story-num-label">Weeks QLD Finishing</div>
        </div>
        <div class="story-num">
          <div class="story-num-val">100%</div>
          <div class="story-num-label">ADR Compliant</div>
        </div>
        <div class="story-num">
          <div class="story-num-val">10+</div>
          <div class="story-num-label">Years Manufacturing</div>
        </div>
        <div class="story-num">
          <div class="story-num-val">QLD</div>
          <div class="story-num-label">Family Business</div>
        </div>
      </div>
    </div>
  </section>

  <!-- EXPEDITION HIGHLIGHT -->
  <section style="background: var(--dark); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 7rem var(--gutter)">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; max-width: var(--max-width); margin: 0 auto">
      <div>
        <div class="section-eyebrow reveal">
          <div class="section-eyebrow-line"></div>
          <span class="section-eyebrow-text">Expedition Range</span>
        </div>
        <h2 class="section-title reveal reveal-delay-1">For the ones<br>who <span style="color: var(--orange)">go furthest.</span></h2>
        <p style="font-size: 0.95rem; color: var(--muted); line-height: 1.8; margin-top: 1.5rem; max-width: 420px" class="reveal reveal-delay-2">
          Beyond RV builds on Unimog and Isuzu NPS platforms for overlanders who genuinely leave all roads behind.
          Full composite bodies. Custom-built to order in Queensland.
        </p>
        <div style="margin-top: 2.5rem" class="reveal reveal-delay-3">
          <a href="/expedition/" class="btn-primary">Explore Expedition Range</a>
        </div>
      </div>
      <div style="aspect-ratio: 16/10; overflow: hidden; position: relative" class="reveal reveal-delay-1">
        <img src="/images/site/unimog-hero.jpg" alt="Beyond RV Unimog expedition vehicle" style="width: 100%; height: 100%; object-fit: cover; filter: brightness(0.8)" />
      </div>
    </div>
  </section>

  <!-- HOW YOUR BUILD WORKS -->
  <section class="build-process">
    <div class="container">
      <div class="section-eyebrow reveal">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-text">The Process</span>
      </div>
      <h2 class="section-title reveal reveal-delay-1">How Your<br><span style="color: var(--orange)">Build Works</span></h2>
      <p class="section-sub reveal reveal-delay-2">
        Five steps from first contact to handing over the keys — all managed out of our Mutdapilly workshop.
      </p>
      <div class="build-steps">
        <div class="build-step reveal">
          <div class="build-step-num">01</div>
          <div class="build-step-body">
            <div class="build-step-title">Tell Us Your Vehicle</div>
            <div class="build-step-desc">Share your truck make, model and tray configuration. We work across HiLux, Ranger, Isuzu, Iveco, Unimog and custom platforms.</div>
          </div>
        </div>
        <div class="build-step reveal reveal-delay-1">
          <div class="build-step-num">02</div>
          <div class="build-step-body">
            <div class="build-step-title">Choose Your Build</div>
            <div class="build-step-desc">Slide-on camper, caravan or full expedition fitout. We walk you through the options that suit your vehicle and your travel style.</div>
          </div>
        </div>
        <div class="build-step reveal reveal-delay-2">
          <div class="build-step-num">03</div>
          <div class="build-step-body">
            <div class="build-step-title">Confirm Dimensions, Payload &amp; Requirements</div>
            <div class="build-step-desc">We lock in the specs — tray dimensions, GVM payload, electrical requirements and any custom fitout. No surprises later.</div>
          </div>
        </div>
        <div class="build-step reveal reveal-delay-3">
          <div class="build-step-num">04</div>
          <div class="build-step-body">
            <div class="build-step-title">Queensland Fitout &amp; Compliance</div>
            <div class="build-step-desc">Our Mutdapilly team completes the full electrical, cabinetry, plumbing and finishing. Every build is checked against the relevant Australian compliance requirements before it leaves the floor.</div>
          </div>
        </div>
        <div class="build-step reveal reveal-delay-4">
          <div class="build-step-num">05</div>
          <div class="build-step-body">
            <div class="build-step-title">Handover &amp; Ongoing Support</div>
            <div class="build-step-desc">We walk you through your build at handover and stay available for questions, servicing and warranty claims — Queensland-based, not a call centre.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST -->
  <section class="trust">
    <div class="section-eyebrow reveal">
      <div class="section-eyebrow-line"></div>
      <span class="section-eyebrow-text">Why Beyond RV</span>
    </div>
    <h2 class="section-title reveal reveal-delay-1">Built Different</h2>
    <div class="trust-grid">
      <div class="trust-card reveal reveal-delay-1">
        <div class="trust-icon">⚡</div>
        <div class="trust-title">Full Electrical Fitout</div>
        <div class="trust-desc">Every wire run by our QLD team. Solar, lithium battery, 240V, 12V — all to Australian standards.</div>
      </div>
      <div class="trust-card reveal reveal-delay-2">
        <div class="trust-icon">🔧</div>
        <div class="trust-title">Truck Compatibility</div>
        <div class="trust-desc">We build to your vehicle's specific tray and payload. Utes to Unimogs — we've fitted them all.</div>
      </div>
      <div class="trust-card reveal reveal-delay-3">
        <div class="trust-icon">🛡</div>
        <div class="trust-title">Australian Warranty</div>
        <div class="trust-desc">Full structural and fitout warranty. We stand behind every build we finish and every part we specify.</div>
      </div>
      <div class="trust-card reveal reveal-delay-4">
        <div class="trust-icon">⛺</div>
        <div class="trust-title">Custom Builds</div>
        <div class="trust-desc">No catalogue limits. Tell us exactly what you need. We design it. We build it. Done.</div>
      </div>
    </div>
  </section>

  <!-- RECENT BUILDS & FITOUTS -->
  <section class="workshop-gallery">
    <div class="container">
      <div class="section-eyebrow reveal">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-text">Recent Builds &amp; Fitouts</span>
      </div>
      <h2 class="section-title reveal reveal-delay-1">Recent Builds<br><span style="color: var(--orange)">&amp; Fitouts</span></h2>
      <p class="section-sub reveal reveal-delay-2">
        Every build that leaves Mutdapilly goes through the same process — specified, fitted and certified by our Queensland team.
      </p>
      <div class="workshop-grid reveal reveal-delay-2">

        <div class="workshop-card">
          <div class="workshop-card-image">
            <img src="/images/products/advent-2150/advent-2150-04.jpg" alt="Advent 2150 slide-on build — Mutdapilly Queensland" />
          </div>
          <div class="workshop-card-body">
            <div class="workshop-card-title">Advent 2150 — Dual-Cab HiLux Build</div>
            <div class="workshop-card-tags">
              <span class="workshop-tag">Finished in Mutdapilly, Queensland</span>
              <span class="workshop-tag">Electrical, cabinetry &amp; compliance completed locally</span>
              <span class="workshop-tag">ADR certified</span>
            </div>
          </div>
        </div>

        <div class="workshop-card">
          <div class="workshop-card-image">
            <img src="/images/site/mog2.jpg" alt="Unimog U1700L expedition build — Beyond RV Queensland" />
          </div>
          <div class="workshop-card-body">
            <div class="workshop-card-title">Built for a Unimog U1700L</div>
            <div class="workshop-card-tags">
              <span class="workshop-tag">Finished in Mutdapilly, Queensland</span>
              <span class="workshop-tag">Electrical, cabinetry &amp; compliance completed locally</span>
              <span class="workshop-tag">Full custom expedition fitout</span>
            </div>
          </div>
        </div>

        <div class="workshop-card">
          <div class="workshop-card-image">
            <img src="/images/products/advent-2300/advent-2300-03.jpg" alt="Advent 2300 slide-on build — Mutdapilly" />
          </div>
          <div class="workshop-card-body">
            <div class="workshop-card-title">Advent 2300 — Isuzu D-Max Build</div>
            <div class="workshop-card-tags">
              <span class="workshop-tag">Finished in Mutdapilly, Queensland</span>
              <span class="workshop-tag">Solar, lithium &amp; 240V fitout</span>
              <span class="workshop-tag">Queensland warranty &amp; ongoing support</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CUSTOMER TESTIMONIALS -->
  <section class="testimonials-section">
    <div class="container">
      <div class="section-eyebrow reveal">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-text">What Customers Say</span>
      </div>
      <h2 class="section-title reveal reveal-delay-1">Built to Last.<br><span style="color: var(--orange)">Backed by Real Owners.</span></h2>
      <div class="testimonials-grid">

        <div class="testimonial-card reveal">
          <p class="testimonial-quote">Can't tell you how bloody ripped I am to have my own House Truck! Li and his team worked round the clock to get my rig not just great but beyond my expectations. I can't recommend these guys enough.</p>
          <div class="testimonial-author">
            <strong>— Farmer Dave</strong>
            <span>House Truck Build · SE Queensland</span>
          </div>
        </div>

        <div class="testimonial-card reveal reveal-delay-1">
          <p class="testimonial-quote">We were able to drive all the way out to Lake Eyre on a 4x4 road that caravans and trailers were banned from. Having your slide-on on our small AWD truck is perhaps one of the highlights of our travelling life.</p>
          <div class="testimonial-author">
            <strong>— Graeme S.</strong>
            <span>Slide-On · AWD Truck · South Australia</span>
          </div>
        </div>

        <div class="testimonial-card reveal reveal-delay-2">
          <p class="testimonial-quote">A big shout out to Li, Alex, Oscar and Melissa at Beyond RV. Worth the wait. We love the set-up, the quality of the build and the space that we have.</p>
          <div class="testimonial-author">
            <strong>— Malcolm &amp; Dianne B.</strong>
            <span>Custom Build · Isuzu NPR · South Australia</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq">
    <div class="faq-grid">
      <div class="faq-sticky">
        <div class="section-eyebrow reveal">
          <div class="section-eyebrow-line"></div>
          <span class="section-eyebrow-text">FAQ</span>
        </div>
        <h2 class="section-title reveal reveal-delay-1">Common<br>Questions</h2>
        <p style="font-size:0.85rem; color:var(--muted); line-height:1.7; margin-top:1rem" class="reveal reveal-delay-2">
          Can't find what you're after? Call us directly.
        </p>
        <a href="tel:+61430863819" class="btn-primary" style="display:inline-block; margin-top:2rem">Call 0430 863 819</a>
      </div>

      <div class="faq-list reveal">
        <div class="faq-item open">
          <button class="faq-question">
            What is a slide-on camper for a ute?
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p>A slide-on camper (also called a truck camper or ute camper) is a self-contained living unit that sits in the tray of a ute or truck. Unlike a caravan, it doesn't tow — it mounts directly onto the vehicle, giving you full off-road capability. Beyond RV builds slide-ons for utes like the HiLux and Ranger, right through to Unimogs and custom expedition trucks.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            Can you build a slide-on camper for a Unimog?
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p>Yes — we're one of the few manufacturers in Australia building bespoke camper units for Unimogs. We design to your specific chassis, wheelbase and payload. Unimog builds are fully custom — all specified and fitted in our Queensland workshop.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            Are Beyond RV campers ADR compliant?
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p>Yes. All Beyond RV builds are finished and certified in Queensland to meet Australian Design Rules (ADR) and relevant road safety standards. We handle compliance documentation as part of every build.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            Where are Beyond RV campers made?
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p>We source high-quality base units globally, then complete all electrical fitout, cabinetry, plumbing, customisation and finishing at our workshop in Mutdapilly, Queensland. This typically takes 3–6 weeks.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            What's the difference between your caravan and slide-on range?
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p>Our caravans are towed behind your vehicle — great for families and longer-term travel. Our slide-on campers mount onto your ute or truck tray, keeping your full off-road capability. For serious 4WD adventurers and expedition travel, slide-ons are the preferred choice.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            How do I get a quote for a custom slide-on build?
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
