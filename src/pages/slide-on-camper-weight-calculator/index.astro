---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { displayImageUrl } from '../../lib/media';

const pageUrl = 'https://beyondrv.com.au/slide-on-camper-weight-calculator/';
const heroImage = '/images/site/homepage-slide-on-campers.webp';
const disclaimer = 'This tool provides an estimate only. Final suitability depends on your exact vehicle variant, compliance plate, manufacturer specifications, towbar rating, axle limits, tyre ratings, accessories, real loaded weights and certified weighbridge results. ByondRV must confirm final suitability before purchase.';

const faqs = [
  {
    q: 'What is available payload?',
    a: 'Available payload is the amount of weight left before your vehicle reaches GVM after you allow for its current weight, passengers, accessories, fuel, water, tools and gear.'
  },
  {
    q: 'Does tray size matter as much as payload?',
    a: 'Yes. A slide-on camper must suit the physical tray or tub as well as the manufacturer ratings and loaded weight limits. Tray length, tray width, centre of gravity and rear overhang all matter.'
  },
  {
    q: 'Should I use tare weight or weighbridge weight?',
    a: 'Use a current weighbridge weight whenever possible. Tare figures often do not include accessories, tray changes, bull bars, winches, canopies or real touring gear.'
  }
];

const products = [
  { name: 'Advent 2150 Hardtop Ute Slide-On Camper', url: 'https://beyondrv.com.au/advent-2150-hardtop-slide-on/', fit: 'Compact hardtop option for suitable space cab and selected dual cab utes.', dryWeight: 'Manual entry required' },
  { name: 'Advent 2300 Hardtop Ute Slide-On Camper', url: 'https://beyondrv.com.au/advent-2300-hardtop-slide-on/', fit: 'Mid-size hardtop slide-on for suitable ute tray platforms.', dryWeight: 'Manual entry required' },
  { name: 'Advent 2450 Hardtop Ute Slide-On Camper', url: 'https://beyondrv.com.au/advent-2450-hardtop-slide-on/', fit: 'Larger hardtop slide-on for vehicles with more tray and payload capacity.', dryWeight: 'Manual entry required' },
  { name: '7ft Electric Pop-Top Slide-On Camper', url: 'https://beyondrv.com.au/7ft-electric-poptop-slide-on/', fit: 'Lower travel-profile pop-top option for suitable ute platforms.', dryWeight: 'Manual entry required' }
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Slide-On Camper Weight Calculator',
    url: pageUrl,
    description: 'Manual Australian payload and GVM calculator for checking whether a ute may suit a ByondRV slide-on camper.'
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map(item => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a }
    }))
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://beyondrv.com.au/' },
      { '@type': 'ListItem', position: 2, name: 'Vehicle Suitability Checker', item: 'https://beyondrv.com.au/vehicle-suitability-checker/' },
      { '@type': 'ListItem', position: 3, name: 'Slide-On Camper Weight Calculator', item: pageUrl }
    ]
  },
  ...products.map(product => ({
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: product.name,
    url: product.url,
    brand: { '@type': 'Brand', name: 'ByondRV' },
    category: 'Slide-on camper'
  }))
];
---
<BaseLayout
  title="Slide-On Camper Weight Calculator | ByondRV"
  description="Estimate whether your ute has enough payload, GVM margin and tray size for a ByondRV slide-on camper. Manual Australian calculator for non-technical buyers."
  image={heroImage}
  activePath="/vehicle-suitability-checker/"
  structuredData={schema}
>
  <section class="page-hero page-hero--short">
    <div class="page-hero-bg" style={`background-image: url('${displayImageUrl(heroImage, 1600)}')`}></div>
    <div class="hero-overlay"></div>
    <div class="hero-overlay-bottom"></div>
    <div class="page-hero-content">
      <div class="section-eyebrow">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-text">Slide-On Camper Weight Calculator</span>
      </div>
      <h1 class="hero-title">Can Your Ute Carry a Slide-On?</h1>
      <p class="hero-sub">
        Enter your own vehicle figures to estimate payload, loaded vehicle weight, GVM margin and which ByondRV slide-on range may be worth discussing.
      </p>
    </div>
  </section>

  <section class="container checker-layout">
    <div class="checker-panel">
      <form class="checker-form" id="slideCalculator">
        <div class="form-field form-field--full">
          <label class="form-label" for="vehicleName">Vehicle</label>
          <input class="form-input" id="vehicleName" type="text" placeholder="Example: Ford Ranger dual cab" />
        </div>
        <div class="form-field">
          <label class="form-label" for="gvm">Vehicle GVM (kg)</label>
          <input class="form-input" id="gvm" type="number" min="0" placeholder="3350" />
        </div>
        <div class="form-field">
          <label class="form-label" for="currentWeight">Current vehicle weight before listed additions (kg)</label>
          <input class="form-input" id="currentWeight" type="number" min="0" placeholder="2200" />
          <span class="form-help">Use a current weighbridge weight if possible. If it already includes passengers or accessories, enter 0 for those items below.</span>
        </div>
        <div class="form-field">
          <label class="form-label" for="passengers">Passengers (kg)</label>
          <input class="form-input" id="passengers" type="number" min="0" placeholder="180" />
        </div>
        <div class="form-field">
          <label class="form-label" for="accessories">Accessories already fitted (kg)</label>
          <input class="form-input" id="accessories" type="number" min="0" placeholder="80" />
          <span class="form-help">Only include bull bar, winch, canopy, drawers, racks or battery weight not already counted above.</span>
        </div>
        <div class="form-field">
          <label class="form-label" for="luggageGear">Vehicle luggage and gear (kg)</label>
          <input class="form-input" id="luggageGear" type="number" min="0" placeholder="120" />
        </div>
        <div class="form-field">
          <label class="form-label" for="camperDry">Camper dry weight (kg)</label>
          <input class="form-input" id="camperDry" type="number" min="0" placeholder="650" />
        </div>
        <div class="form-field">
          <label class="form-label" for="camperWater">Camper water weight (kg)</label>
          <input class="form-input" id="camperWater" type="number" min="0" placeholder="80" />
        </div>
        <div class="form-field">
          <label class="form-label" for="camperGear">Camper gear weight (kg)</label>
          <input class="form-input" id="camperGear" type="number" min="0" placeholder="100" />
        </div>
        <div class="form-field">
          <label class="form-label" for="camperOptions">Camper options weight (kg)</label>
          <input class="form-input" id="camperOptions" type="number" min="0" placeholder="50" />
        </div>
        <div class="form-field">
          <label class="form-label" for="trayLength">Tray or tub usable length (mm)</label>
          <input class="form-input" id="trayLength" type="number" min="0" placeholder="2150" />
        </div>
        <div class="form-field">
          <label class="form-label" for="trayWidth">Tray or tub usable width (mm)</label>
          <input class="form-input" id="trayWidth" type="number" min="0" placeholder="1850" />
        </div>
        <div class="form-field">
          <label class="form-label" for="requiredTrayLength">Required tray length (mm)</label>
          <input class="form-input" id="requiredTrayLength" type="number" min="0" placeholder="2100" />
        </div>
        <div class="form-field">
          <label class="form-label" for="requiredTrayWidth">Required tray width (mm)</label>
          <input class="form-input" id="requiredTrayWidth" type="number" min="0" placeholder="1750" />
        </div>
        <div class="form-field">
          <label class="form-label" for="rearAxleChecked">Rear axle limits checked</label>
          <input id="rearAxleChecked" type="checkbox" />
        </div>
        <div class="form-field">
          <label class="form-label" for="tyreRatingsChecked">Tyre ratings checked</label>
          <input id="tyreRatingsChecked" type="checkbox" />
        </div>
        <div class="form-field">
          <label class="form-label" for="centreOfGravityChecked">Centre of gravity checked</label>
          <input id="centreOfGravityChecked" type="checkbox" />
        </div>
      </form>
      <p class="calculator-disclaimer">{disclaimer}</p>
    </div>

    <aside class="result-panel" id="resultPanel" data-status="neutral" aria-live="polite">
      <div class="result-status" id="statusLabel">Enter your numbers to calculate a result.</div>
      <h2 id="resultTitle">Enter your numbers</h2>
      <p class="result-summary" id="resultSummary">Enter your numbers to calculate a result.</p>
      <div class="result-metrics">
        <div class="result-metric"><span>Available payload before camper</span><strong id="availablePayload">0 kg</strong></div>
        <div class="result-metric"><span>Estimated loaded vehicle weight</span><strong id="loadedWeight">0 kg</strong></div>
        <div class="result-metric"><span>Remaining GVM margin</span><strong id="gvmMargin">0 kg</strong></div>
        <div class="result-metric"><span>Estimated loaded camper weight</span><strong id="loadedCamper">0 kg</strong></div>
        <div class="result-metric"><span>Tray length fit</span><strong id="trayLengthFit">0 mm</strong></div>
        <div class="result-metric"><span>Tray width fit</span><strong id="trayWidthFit">0 mm</strong></div>
        <div class="result-metric"><span>Data quality</span><strong id="dataQuality">Needs review</strong></div>
      </div>
      <div class="result-recommendation">
        <strong>ByondRV product recommendation</strong>
        <p id="recommendation">Confirm with ByondRV</p>
      </div>
      <ul class="result-notes" id="warningNotes"></ul>
      <a class="btn-primary" id="sendResult" href="/inquiry-form/?intent=vehicle-suitability">Send this result to ByondRV</a>
    </aside>
  </section>

  <section class="authority-section authority-section--dark">
    <div class="container authority-copy">
      <h2>How this slide-on camper calculator works</h2>
      <p>
        The calculator starts with your vehicle GVM, subtracts the current vehicle weight, then allows for passengers, accessories, the camper dry weight and the loaded camper weight. It also flags tray dimensions because a ute can have enough payload but still be physically unsuitable.
      </p>
      <p>
        This is a GVM and fit estimate only. Final suitability also depends on axle ratings, tyre ratings, tray or tub rating, mounting method, load distribution, suspension setup and certified weighbridge results.
      </p>
      <div class="worked-example">
        <h3>Worked example</h3>
        <p>A ute with 3350kg GVM and a 2400kg current weighbridge weight has 950kg before it reaches GVM. If passengers, accessories and loaded camper weight add 1130kg, the vehicle is estimated at 3530kg loaded. That is 180kg over GVM, so the result is red.</p>
      </div>
      <h2>ByondRV slide-on product data table</h2>
      <div class="authority-table-wrap">
        <table class="authority-table">
          <thead>
            <tr>
              <th>Product</th>
              <th>Data status</th>
              <th>Data needed</th>
            </tr>
          </thead>
          <tbody>
            {products.map(product => (
              <tr>
                <td><a href={new URL(product.url).pathname}>{product.name}</a></td>
                <td>Confirm with ByondRV</td>
                <td>{product.dryWeight}, tray size, GVM margin, axle limits and weighbridge result.</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="container authority-section">
    <div class="authority-copy">
      <h2>Slide-on camper FAQ</h2>
      <div class="faq-list">
        {faqs.map(item => (
          <details>
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { calculateSlideOnSuitability } from '../../lib/vehicleSuitabilityCalculator.js';

  const form = document.getElementById('slideCalculator');
  const resultPanel = document.getElementById('resultPanel');
  const fields = ['vehicleName', 'gvm', 'currentWeight', 'passengers', 'accessories', 'luggageGear', 'camperDry', 'camperWater', 'camperGear', 'camperOptions', 'trayLength', 'trayWidth', 'requiredTrayLength', 'requiredTrayWidth', 'rearAxleChecked', 'tyreRatingsChecked', 'centreOfGravityChecked'];
  let hasStarted = false;
  const byId = (id: string) => document.getElementById(id);
  const inputById = (id: string) => document.getElementById(id) as HTMLInputElement | null;
  const value = (id: string) => inputById(id)?.value ?? '';
  const fmt = (value: number) => `${Math.round(value).toLocaleString()} kg`;
  const fmtMm = (value: number) => `${Math.round(value).toLocaleString()} mm`;
  type SlideOnResultValues = {
    availablePayloadBeforeCamper?: number;
    estimatedLoadedVehicleWeight?: number;
    remainingGvmMargin?: number;
    estimatedLoadedCamperWeight?: number;
    trayLengthFit?: number;
    trayWidthFit?: number;
  };
  const kgOrZero = (value?: number) => value === undefined ? '0 kg' : fmt(value);
  const mmOrZero = (value?: number) => value === undefined ? '0 mm' : fmtMm(value);
  const kgOrNotCalculated = (value?: number) => value === undefined ? 'Not calculated' : fmt(value);
  const mmOrNotCalculated = (value?: number) => value === undefined ? 'Not calculated' : fmtMm(value);

  function setText(id: string, value: string) {
    const el = byId(id);
    if (el) el.textContent = value;
  }

  function setNotes(notes: string[]) {
    const warningNotes = byId('warningNotes');
    if (!warningNotes) return;
    warningNotes.replaceChildren();
    notes.forEach((note: string) => {
      const item = document.createElement('li');
      item.textContent = note;
      warningNotes.appendChild(item);
    });
  }

  function calculateSlideOn() {
    const vehicleName = inputById('vehicleName')?.value || 'your vehicle';
    const result = calculateSlideOnSuitability({
      vehicleGvm: value('gvm'),
      currentVehicleWeight: value('currentWeight'),
      passengerWeight: value('passengers'),
      accessoryWeight: value('accessories'),
      luggageOrGearWeight: value('luggageGear'),
      camperDryWeight: value('camperDry'),
      camperWaterWeight: value('camperWater'),
      camperGearWeight: value('camperGear'),
      camperOptionsWeight: value('camperOptions'),
      trayLength: value('trayLength'),
      trayWidth: value('trayWidth'),
      requiredTrayLength: value('requiredTrayLength'),
      requiredTrayWidth: value('requiredTrayWidth'),
      rearAxleChecked: inputById('rearAxleChecked')?.checked ?? false,
      tyreRatingsChecked: inputById('tyreRatingsChecked')?.checked ?? false,
      centreOfGravityChecked: inputById('centreOfGravityChecked')?.checked ?? false
    }, { started: hasStarted });
    const values: SlideOnResultValues = 'values' in result ? result.values : {};

    resultPanel?.setAttribute('data-status', result.status);
    setText('statusLabel', result.statusLabel);
    setText('resultTitle', result.title);
    setText('resultSummary', result.summary);
    setText('availablePayload', kgOrZero(values.availablePayloadBeforeCamper));
    setText('loadedWeight', kgOrZero(values.estimatedLoadedVehicleWeight));
    setText('gvmMargin', kgOrZero(values.remainingGvmMargin));
    setText('loadedCamper', kgOrZero(values.estimatedLoadedCamperWeight));
    setText('trayLengthFit', mmOrZero(values.trayLengthFit));
    setText('trayWidthFit', mmOrZero(values.trayWidthFit));
    setText('dataQuality', result.dataQuality);
    setText('recommendation', result.recommendation);
    setNotes(result.notes);

    const message = [
      'Vehicle Suitability Checker result - slide-on camper',
      `Vehicle: ${vehicleName}`,
      `Status: ${result.statusLabel}`,
      `Available payload before camper: ${kgOrNotCalculated(values.availablePayloadBeforeCamper)}`,
      `Estimated loaded vehicle weight: ${kgOrNotCalculated(values.estimatedLoadedVehicleWeight)}`,
      `Remaining GVM margin: ${kgOrNotCalculated(values.remainingGvmMargin)}`,
      `Estimated loaded camper weight: ${kgOrNotCalculated(values.estimatedLoadedCamperWeight)}`,
      `Tray length fit: ${mmOrNotCalculated(values.trayLengthFit)}`,
      `Tray width fit: ${mmOrNotCalculated(values.trayWidthFit)}`,
      `Data quality: ${result.dataQuality}`,
      `Recommendation: ${result.recommendation}`
    ].join('\n');
    const send = byId('sendResult');
    if (send) send.setAttribute('href', `/inquiry-form/?intent=vehicle-suitability&message=${encodeURIComponent(message)}&fit_check_summary=${encodeURIComponent(message)}`);
  }

  fields.forEach(id => byId(id)?.addEventListener('input', () => {
    hasStarted = true;
    calculateSlideOn();
  }));
  form?.addEventListener('submit', (event) => event.preventDefault());
</script>
