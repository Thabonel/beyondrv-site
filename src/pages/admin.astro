---
import AdminPanel from '../components/AdminPanel';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ByondRV Admin</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { height: 100%; background: #0a0a0a; color: #fff; font-family: 'Outfit', system-ui, sans-serif; }
      header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 0 1rem; height: 60px;
        background: #111; border-bottom: 1px solid #333;
      }
      header img { height: 36px; }
      header span { color: #888; font-size: 0.85rem; }
    </style>
  </head>
  <body>
    <header>
      <div style="display:flex;align-items:center;gap:1.5rem">
        <img src="/images/site/logo.png" alt="ByondRV" />
        <nav style="display:flex">
          <a href="/admin" style="color:#fff;text-decoration:none;font-size:0.85rem;padding:0.3rem 0.75rem;background:#1a1a1a;border-radius:4px">Admin</a>
          <a href="/admin/analytics" style="color:#888;text-decoration:none;font-size:0.85rem;padding:0.3rem 0.75rem;border-radius:4px;margin-left:0.5rem">Analytics</a>
        </nav>
      </div>
      <span>Site Admin — changes deploy directly to production</span>
    </header>
    <AdminPanel client:load />
  </body>
</html>
