---
import AdminPanel from '../components/AdminPanel';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Beyond RV Admin</title>
    <meta name="description" content="Private Beyond RV administration area for managing site content and product information." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href="https://beyondrv.com.au/admin/" />
    <meta property="og:title" content="Beyond RV Admin" />
    <meta property="og:description" content="Private Beyond RV administration area." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { height: 100%; background: #0a0a0a; color: #fff; font-family: 'Outfit', system-ui, sans-serif; }
      header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 0 1rem; height: 60px;
        background: #111; border-bottom: 1px solid #333;
      }
      header img { height: 36px; }
      header span { color: #888; font-size: 0.85rem; }
      .sr-only {
        position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
        overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
      }
      @media (max-width: 900px) {
        header {
          align-items: flex-start;
          gap: 0.75rem;
          padding: 0.75rem 0.8rem;
          height: auto;
          flex-wrap: wrap;
        }
        header img { height: 32px; }
        header nav { display: flex; gap: 0.4rem; flex-wrap: wrap; }
        header nav a { margin-left: 0; }
        .admin-topbar-note { display: none; }
      }
      @media (max-width: 900px) {
        .admin-tab-bar {
          display: flex !important;
          overflow-x: auto;
          overflow-y: hidden;
          -webkit-overflow-scrolling: touch;
          scrollbar-width: none;
          -ms-overflow-style: none;
        }
        .admin-tab-bar::-webkit-scrollbar { display: none; }
        .admin-tab-button {
          flex: 0 0 auto;
          min-width: 92px;
          padding: 0.55rem 0.5rem !important;
          font-size: 0.66rem !important;
          line-height: 1.05;
          white-space: normal;
        }
      }
    </style>
  </head>
  <body>
    <h1 class="sr-only">Beyond RV Admin</h1>
    <header>
      <div style="display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap">
        <img src="/images/site/admin-logo.png" alt="Beyond RV" width="48" height="36" loading="eager" decoding="async" />
        <nav style="display:flex">
          <a href="/admin" style="color:#fff;text-decoration:none;font-size:0.85rem;padding:0.3rem 0.75rem;background:#1a1a1a;border-radius:4px">Admin</a>
          <a href="/admin/analytics" style="color:#888;text-decoration:none;font-size:0.85rem;padding:0.3rem 0.75rem;border-radius:4px;margin-left:0.5rem">Analytics</a>
        </nav>
      </div>
      <span class="admin-topbar-note">Site Admin — changes deploy directly to production</span>
    </header>
    <AdminPanel client:load />
  </body>
</html>
