---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { displayImageUrl, imageSrcSet, thumbImageUrl } from '../../lib/media';
import { formatShopPrice, shopProductPrice, availabilityLabel, canPurchaseOnline, isOnlinePayableFulfilment, fulfilmentInfo, sourceTypeLabel } from '../../lib/shop';
import { ORDER_MAX } from '../../lib/cart';
import { buildMerchantProduct } from '../../lib/structuredData.js';

export async function getStaticPaths() {
  const allProducts = await getCollection('products');
  return allProducts
    .filter((product) => product.data.store === true)
    .map((product) => ({
      params: { slug: product.data.store === true ? product.data.slug : '' },
      props: { product },
    }));
}

interface Props {
  product: Awaited<ReturnType<typeof getCollection<'products'>>>[number];
}

interface GalleryImage {
  original: string;
  display: string;
  thumb: string;
  srcset: string;
}

const { product } = Astro.props;
if (product.data.store !== true) throw new Error('Shop route received a non-shop product');
const { data } = product;
const stockData = data.productType === 'stock' ? data : null;
const isAddable = stockData ? canPurchaseOnline(stockData) && isOnlinePayableFulfilment(stockData.fulfilmentType) : false;
const stockLabel = stockData ? availabilityLabel(stockData.availability) : null;
const fulfilment = stockData ? fulfilmentInfo(stockData.fulfilmentType) : null;
const sourceType = stockData?.sourceType ?? 'other';
const sourceTypeText = stockData ? sourceTypeLabel(sourceType) : '';
const hasItemSpecs = Boolean(stockData?.weight && stockData?.dimensions);
const { Content } = await product.render();
const unitPrice = shopProductPrice(data.price);
const productUrl = `https://beyondrv.com.au/shop/${data.slug}/`;
const itemAdditionalProperty = stockData && hasItemSpecs && stockData.weight && stockData.dimensions
  ? [
      { '@type': 'PropertyValue', name: 'Item weight', value: `${stockData.weight} kg` },
      {
        '@type': 'PropertyValue',
        name: 'Item dimensions',
        value: `${stockData.dimensions.length} × ${stockData.dimensions.width} × ${stockData.dimensions.height} cm`,
      },
    ]
  : undefined;
const structuredData = [
  {
    ...buildMerchantProduct({
      slug: data.slug,
      name: data.name,
      description: data.description,
      url: productUrl,
      image: data.images.map((image: string) => new URL(image, 'https://beyondrv.com.au').toString()),
      price: data.price,
      status: data.status,
      availability: stockData ? stockData.availability : data.availability,
      category: data.category,
    }),
    ...(itemAdditionalProperty ? { additionalProperty: itemAdditionalProperty } : {}),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://beyondrv.com.au/' },
      { '@type': 'ListItem', position: 2, name: 'Shop', item: 'https://beyondrv.com.au/shop/' },
      { '@type': 'ListItem', position: 3, name: data.name, item: productUrl },
    ],
  },
];
const galleryImages: GalleryImage[] = data.images.map((image: string) => ({
  original: image,
  display: displayImageUrl(image, 1200),
  thumb: thumbImageUrl(image),
  srcset: imageSrcSet(image, [480, 800, 1200]),
}));
const mainImage = galleryImages[0]?.display ?? displayImageUrl(data.images[0], 1200);
const mainImageSrcSet = galleryImages[0]?.srcset ?? imageSrcSet(data.images[0], [480, 800, 1200]);
---
<BaseLayout
  title={data.seoTitle ?? `${data.name} | Beyond RV Shop`}
  description={data.seoDesc ?? data.description}
  image={data.images[0]}
  type="product"
  activePath="/shop/"
  canonicalUrl={`/shop/${data.slug}/`}
  structuredData={structuredData}
  preloadImage={{ src: mainImage, srcset: mainImageSrcSet, sizes: '(max-width: 900px) 100vw, 58vw' }}
>
  <section class="shop-detail container">
    <div class="shop-breadcrumbs" role="navigation" aria-label="Breadcrumb">
      <a href="/">Home</a><span aria-hidden="true">/</span>
      <a href="/shop/">Shop</a><span aria-hidden="true">/</span>
      <span aria-current="page">{data.name}</span>
    </div>

    <div class="shop-detail-grid">
      <div class="shop-detail-media">
        <div class="product-gallery">
          <div class="product-gallery-main">
            <img
              id="shopHeroImg"
              src={mainImage}
              srcset={mainImageSrcSet}
              sizes="(max-width: 900px) 100vw, 58vw"
              alt={data.name}
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
            {galleryImages.length > 1 && (
              <div class="product-gallery-controls" aria-label={`${data.name} gallery navigation`}>
                <button class="gallery-nav-btn gallery-nav-prev" type="button" aria-label="Previous photo" data-gallery-prev>
                  ‹
                </button>
                <span class="gallery-count" aria-live="polite">
                  <span data-gallery-current>1</span> / {galleryImages.length}
                </span>
                <button class="gallery-nav-btn gallery-nav-next" type="button" aria-label="Next photo" data-gallery-next>
                  ›
                </button>
              </div>
            )}
          </div>
          {galleryImages.length > 1 && (
            <div class="product-gallery-thumbs">
              {galleryImages.map((image: GalleryImage, index: number) => (
                <button
                  class={`thumb-btn${index === 0 ? ' active' : ''}`}
                  type="button"
                  data-src={image.display}
                  data-srcset={image.srcset}
                  aria-label={`View image ${index + 1} of ${data.name}`}
                >
                  <img src={image.thumb} alt={`${data.name} view ${index + 1}`} loading="lazy" decoding="async" />
                </button>
              ))}
            </div>
          )}
        </div>
      </div>

      <div class="shop-detail-info">
        <span class="shop-product-category">{data.category}</span>
        <h1>{data.name}</h1>
        <p class="shop-detail-description">{data.description}</p>
        <div class="shop-detail-price-stack">
          {stockData?.compareAtPrice !== undefined && shopProductPrice(stockData.compareAtPrice) !== unitPrice && (
            <span class="shop-detail-compare-at">{formatShopPrice(shopProductPrice(stockData.compareAtPrice))}</span>
          )}
          {stockData?.saleLabel && <span class="shop-detail-sale-label">{stockData.saleLabel}</span>}
          <p class="shop-detail-price">{formatShopPrice(unitPrice)}</p>
        </div>
        {stockData && (
          <p class:list={['shop-stock shop-detail-stock', { 'shop-stock--available': stockData.availability === 'available_in_australia' }]}>
            {stockLabel}
          </p>
        )}

        {fulfilment && (
          <p class="shop-fulfilment-note">{fulfilment.message}</p>
        )}

        {stockData?.leadTimeText && <p class="shop-detail-meta">{stockData.leadTimeText}</p>}
        {stockData?.containerEtaText && <p class="shop-detail-meta">{stockData.containerEtaText}</p>}
        {stockData?.containerEtaDate && <p class="shop-detail-meta">ETA date: {stockData.containerEtaDate}</p>}
        {stockData?.sourceType && <p class="shop-detail-meta">{sourceTypeText}</p>}

        {stockData && hasItemSpecs && stockData.weight && stockData.dimensions && (
          <dl class="shop-product-specs">
            <div><dt>Item weight</dt><dd>{stockData.weight} kg</dd></div>
            <div><dt>Item dimensions</dt><dd>{stockData.dimensions.length} &times; {stockData.dimensions.width} &times; {stockData.dimensions.height} cm</dd></div>
          </dl>
        )}

        {isAddable && (
          <div class="shop-cart-actions">
            <button
              class="btn-primary shop-add-to-cart"
              type="button"
              data-add-to-cart
              data-slug={data.slug}
              data-max={ORDER_MAX}
            >
              Add to Cart
            </button>
            <span class="shop-add-feedback" data-add-feedback role="status" aria-live="polite" hidden>Added to cart</span>
          </div>
        )}

        <a
          class:list={[isAddable ? 'btn-ghost' : 'btn-primary', 'shop-enquiry-link']}
          href={`/inquiry-form/?product=${encodeURIComponent(data.slug)}&name=${encodeURIComponent(data.name)}`}
        >
          Ask about availability
        </a>
      </div>
    </div>
  </section>

  <section class="shop-detail-content container">
    <div class="prose">
      <Content />
    </div>
  </section>
</BaseLayout>

<script>
  import { readCart, writeCart, addItem, notifyCartChange } from '../../lib/cart';

  const heroImg = document.getElementById('shopHeroImg') as HTMLImageElement | null;
  const thumbButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.thumb-btn'));
  const galleryCurrent = document.querySelector<HTMLElement>('[data-gallery-current]');
  let activeGalleryIndex = Math.max(0, thumbButtons.findIndex((btn) => btn.classList.contains('active')));

  function showGalleryImage(index: number) {
    if (!heroImg || thumbButtons.length === 0) return;

    const nextIndex = (index + thumbButtons.length) % thumbButtons.length;
    const nextButton = thumbButtons[nextIndex];
    if (!nextButton?.dataset.src) return;

    heroImg.src = nextButton.dataset.src;
    if (nextButton.dataset.srcset) heroImg.srcset = nextButton.dataset.srcset;

    thumbButtons.forEach((btn) => btn.classList.remove('active'));
    nextButton.classList.add('active');
    activeGalleryIndex = nextIndex;
    if (galleryCurrent) galleryCurrent.textContent = String(nextIndex + 1);
  }

  thumbButtons.forEach((btn, index) => {
    btn.addEventListener('click', () => showGalleryImage(index));
  });

  document.querySelector<HTMLButtonElement>('[data-gallery-prev]')?.addEventListener('click', () => {
    showGalleryImage(activeGalleryIndex - 1);
  });

  document.querySelector<HTMLButtonElement>('[data-gallery-next]')?.addEventListener('click', () => {
    showGalleryImage(activeGalleryIndex + 1);
  });

  const button = document.querySelector<HTMLButtonElement>('[data-add-to-cart]');
  const feedback = document.querySelector<HTMLElement>('[data-add-feedback]');

  button?.addEventListener('click', () => {
    const slug = button.dataset.slug;
    const max = Number(button.dataset.max ?? '0');
    if (!slug || max < 1) return;

    writeCart(addItem(readCart(), slug, max));
    notifyCartChange();

    if (feedback) feedback.hidden = false;
    button.textContent = 'Added \u2713';
    window.setTimeout(() => {
      button.textContent = 'Add to Cart';
    }, 1500);
  });
</script>
