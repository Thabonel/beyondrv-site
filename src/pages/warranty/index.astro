---
import BaseLayout from '../../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Warranty | Beyond RV",
  "url": "https://beyondrv.com.au/warranty/",
  "description": "Beyond RV warranty terms — structural and fitout warranty on all builds. Queensland-built, ADR compliant."
};
---
<BaseLayout
  title="Warranty | Beyond RV Queensland-Built Campers"
  description="Beyond RV warranty information. Full structural and fitout warranty on all builds. We stand behind everything we make."
  activePath="/warranty/"
  structuredData={schema}
>
  <section class="page-hero page-hero--short">
    <div class="hero-overlay" style="background: rgba(10,10,10,0.425)"></div>
    <div class="page-hero-content">
      <div class="section-eyebrow">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-text">Warranty</span>
      </div>
      <h1 class="hero-title">We Stand Behind<br><span class="accent">Every Build.</span></h1>
    </div>
  </section>

  <section class="container">
    <div class="page-content">
      <h2>Beyond RV Warranty</h2>
      <p>
        Beyond RV provides a comprehensive warranty on all builds. This covers defects in materials and workmanship
        in the structural components and electrical fitout completed by our Queensland workshop.
      </p>

      <h2>What's Covered</h2>
      <h3>Structural Warranty</h3>
      <p>
        The composite body structure of all Beyond RV builds is warranted against defects in materials and
        workmanship for the warranty period. This includes the shell, floor, roof, and primary structural joins.
      </p>

      <h3>Electrical Fitout</h3>
      <p>
        All electrical work completed by Beyond RV — including solar installation, battery systems, 240V wiring,
        lighting, and 12V accessories — is warranted against defects in materials and workmanship.
      </p>

      <h3>Cabinetry & Fitout</h3>
      <p>
        Cabinetry, plumbing, and interior fitout completed in our workshop is warranted against defects in
        materials and workmanship.
      </p>

      <h2>What's Not Covered</h2>
      <p>The warranty does not cover:</p>
      <ul>
        <li>Normal wear and tear</li>
        <li>Damage resulting from misuse, accidents, or off-road incidents beyond normal use</li>
        <li>Modifications made by the owner or third parties after delivery</li>
        <li>Consumable items (tyres, filters, fluids, light globes, etc.)</li>
        <li>Damage from failure to maintain the unit in accordance with our handover documentation</li>
      </ul>

      <h2>Australian Consumer Law</h2>
      <p>
        Our warranty is in addition to, and does not exclude or limit, your rights under the
        <strong>Australian Consumer Law</strong>. As a consumer, you have statutory rights for goods that are
        not of acceptable quality, not fit for purpose, or not as described — regardless of any voluntary
        warranty we provide.
      </p>
      <p>
        Nothing in this warranty limits your rights under Australian Consumer Law for goods that fail to
        comply with applicable consumer guarantees.
      </p>

      <h2>Making a Warranty Claim</h2>
      <p>
        To make a warranty claim, contact us with your build details and a description of the issue:
      </p>
      <ul>
        <li><strong>Phone:</strong> <a href="tel:+61430863819">0430 863 819</a></li>
        <li><strong>Email:</strong> <a href="mailto:beyondcaravans@gmail.com">beyondcaravans@gmail.com</a></li>
      </ul>

      <p style="margin-top: 2rem; font-size: 0.82rem; color: var(--muted)">
        Last updated: May 2026. Contact Beyond RV for the warranty terms that apply to your specific build.
      </p>
    </div>
  </section>
</BaseLayout>
