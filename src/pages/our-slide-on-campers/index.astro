---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import ProductComparisonTable from '../../components/ProductComparisonTable.astro';
import { displayImageUrl } from '../../lib/media';
import { buildMerchantProduct } from '../../lib/structuredData.js';

const productOrder = [
  'advent-2150-hardtop-slide-on',
  'advent-2300-hardtop-slide-on',
  'advent-2450-hardtop-slide-on',
  '7ft-electric-poptop-slide-on',
];
const allProducts = await getCollection('products');
type ProductEntry = typeof allProducts[number];
const isProduct = (product: ProductEntry | undefined): product is ProductEntry => Boolean(product);
const products = productOrder
  .map(slug => allProducts.find(p => p.slug === slug))
  .filter(isProduct);

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Beyond RV Slide-On Campers",
  "url": "https://beyondrv.com.au/our-slide-on-campers/",
  "hasPart": products.map(p => {
    const productUrl = `https://beyondrv.com.au/${p.slug}/`;
    return buildMerchantProduct({
      slug: p.slug,
      name: p.data.title,
      description: p.data.seoDesc ?? p.data.tagline,
      url: productUrl,
      image: new URL(p.data.heroImage, 'https://beyondrv.com.au').toString(),
      price: p.data.price,
      status: p.data.status,
      availability: p.data.availability,
      category: 'Slide-On Campers',
    });
  })
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What vehicles can take a Beyond RV slide-on camper?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Beyond RV works with utes, tray backs, mid-size trucks, and larger expedition platforms. Suitability depends on tray size, payload, axle limits, and how the vehicle is set up."
      }
    },
    {
      "@type": "Question",
      "name": "Should I choose a hardtop or pop-top slide-on?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Hardtops suit buyers who want fixed interior height and simple setup. Pop-tops suit buyers who want a lower travel profile and standing room once camped."
      }
    }
  ]
};
const heroImage = '/images/site/homepage-slide-on-campers.webp';
---
<BaseLayout
  title="Slide-On Campers for Utes | Beyond RV Queensland"
  description="Beyond RV ute slide-on campers — hardtop and pop-top campers for suitable ute tray platforms. The Advent range and 7ft electric pop-top. Built in Queensland."
  image={heroImage}
  activePath="/our-slide-on-campers/"
  structuredData={[schema, faqSchema]}
>
  <section class="page-hero">
    <div class="page-hero-bg" style={`background-image: url('${displayImageUrl(heroImage, 1600)}')`}></div>
    <div class="hero-overlay"></div>
    <div class="hero-overlay-bottom"></div>
    <div class="page-hero-content">
      <div class="section-eyebrow">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-text">Slide-On Campers</span>
      </div>
      <h1 class="hero-title">Slide-On Campers</h1>
      <p class="hero-sub">
        For suitable ute tray platforms. Hardtop and pop-top models across multiple size classes.
        Full composite. Queensland finished.
      </p>
    </div>
  </section>

  <section class="category-grid container">
    <div class="product-grid">
      {products.map(p => (
          <ProductCard
            title={p.data.title}
            slug={p.slug}
            category={p.data.category}
            tagline={p.data.tagline}
            price={p.data.price}
            status={p.data.status}
            heroImage={p.data.heroImage}
            priceBadge={p.data.priceBadge}
            compareAtPrice={p.data.compareAtPrice}
            saleLabel={p.data.saleLabel}
            availability={p.data.availability}
            sourceType={p.data.sourceType}
          />
        ))}
      </div>
  </section>

  <ProductComparisonTable
    title="Slide-On Campers"
    intro="Quickly compare the Advent range and 7ft pop-top by price, fitment, sleeping layout, construction, and the kind of vehicle setup each one suits. Any field that is not explicitly confirmed stays marked as To be confirmed."
    products={products}
  />

  <section class="container" style="padding-bottom: 5rem">
    <div class="page-content">
      <h2>Choosing a slide-on camper</h2>
      <h3>What vehicles can take a slide-on camper?</h3>
      <p>
        The right slide-on depends on tray size, payload, axle limits, suspension setup, and how much water,
        battery, and gear you want to carry. Beyond RV's Slide-Ons range is dedicated to ute slide-on campers.
      </p>
      <h3>Hardtop or pop-top?</h3>
      <p>
        Choose a hardtop when you want fixed living height and quick access. Choose a pop-top when travel
        height and wind resistance matter, but you still want standing room at camp.
      </p>
      <p>
        For truck campers, Unimog bodies, Isuzu NPS builds, or larger expedition bodies, compare the
        <a href="/expedition/">Expedition range</a>.
      </p>
    </div>
  </section>

  <section class="cta-section" style="padding: 7rem var(--gutter)">
    <div class="cta-bg" style="background-image: url('/images/site/unimog-hero.jpg')"></div>
    <div class="cta-overlay"></div>
    <div class="cta-content">
      <h2 class="cta-title reveal">Need a <span class="italic">custom fit?</span></h2>
      <p class="cta-sub reveal reveal-delay-1">Tell us your truck, your tray size, and how you travel. We'll build to spec.</p>
      <div class="cta-actions reveal reveal-delay-2">
        <a href="/custom/" class="btn-primary">Custom Build Enquiry</a>
        <a href="tel:+61430863819" class="btn-ghost">Call 0430 863 819</a>
      </div>
    </div>
  </section>
</BaseLayout>
