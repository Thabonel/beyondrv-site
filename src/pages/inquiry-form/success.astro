---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Enquiry Sent | ByondRV"
  description="Thanks for getting in touch with ByondRV. We'll be in touch soon."
  noIndex={true}
>
  <section class="not-found-section" style="justify-content: center; text-align: center; flex-direction: column">
    <div class="not-found-content" style="max-width: 600px; margin: 0 auto; text-align: center">
      <div class="section-eyebrow" style="justify-content: center">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-text">Enquiry Received</span>
      </div>
      <h1 class="hero-title">You're on the <span class="accent">map.</span></h1>
      <p class="hero-sub" style="margin-left: auto; margin-right: auto; text-align: center">
        Thanks for reaching out. We'll give you a call back at your preferred time.
        In the meantime, feel free to keep browsing the range.
      </p>
      <div class="hero-actions" style="justify-content: center; margin-top: 2rem">
        <a href="/" class="btn-primary">Back to Home</a>
        <a href="/our-slide-on-campers/" class="btn-ghost">Browse Campers</a>
      </div>
    </div>
  </section>
</BaseLayout>
