---
import BaseLayout from '../../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Beyond RV Enquiry Form",
  "url": "https://beyondrv.com.au/inquiry-form/",
  "description": "Send an enquiry to Beyond RV. We'll call you back at a time that suits."
};
---
<BaseLayout
  title="Enquire | Beyond RV — We'll Call You Back"
  description="Get in touch with Beyond RV. Tell us what you're interested in and when to call you back. No pressure, no sales scripts."
  activePath="/inquiry-form/"
  structuredData={schema}
>
  <section class="page-hero page-hero--short">
    <div class="hero-overlay" style="background: rgba(10,10,10,0.425)"></div>
    <div class="page-hero-content">
      <div class="section-eyebrow">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-text">Get In Touch</span>
      </div>
      <h1 class="hero-title">Enquire Now</h1>
      <p class="hero-sub">
        Tell us what you're after and when's a good time for us to give you a call.
        No pressure. Just a conversation.
      </p>
    </div>
  </section>

  <section class="enquiry-form-section container">
    <form
      name="beyondrv-enquiry"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="enquiry-form"
      id="enquiryForm"
      action="/inquiry-form/success/"
    >
      <input type="hidden" name="form-name" value="beyondrv-enquiry" />
      <input type="hidden" name="product_interest" id="productInterestField" value="" />
      <input type="hidden" name="enquiry_intent" id="intentField" value="" />
      <input type="hidden" name="referral_partner" id="referralPartner" value="" />
      <input type="hidden" name="referral_entry_page" id="referralEntryPage" value="" />
      <input type="hidden" name="referral_first_touch" id="referralFirstTouch" value="" />
      <input type="hidden" name="referral_utm_source" id="referralUtmSource" value="" />
      <input type="hidden" name="referral_utm_campaign" id="referralUtmCampaign" value="" />

      <p style="display:none">
        <label>Don't fill this out if you're human: <input name="bot-field" /></label>
      </p>

      <div class="form-field">
        <label class="form-label" for="name">
          Full Name <span aria-hidden="true" style="color:var(--orange)">*</span>
        </label>
        <input
          class="form-input"
          type="text"
          id="name"
          name="name"
          required
          autocomplete="name"
          placeholder="Your name"
        />
      </div>

      <div class="form-field">
        <label class="form-label" for="email">
          Email <span aria-hidden="true" style="color:var(--orange)">*</span>
        </label>
        <input
          class="form-input"
          type="email"
          id="email"
          name="email"
          required
          autocomplete="email"
          placeholder="your@email.com"
        />
      </div>

      <div class="form-field">
        <label class="form-label" for="phone">
          Phone <span aria-hidden="true" style="color:var(--orange)">*</span>
        </label>
        <input
          class="form-input"
          type="tel"
          id="phone"
          name="phone"
          required
          autocomplete="tel"
          placeholder="Your best contact number"
        />
      </div>

      <div class="form-field">
        <label class="form-label" for="message">
          Message <span aria-hidden="true" style="color:var(--orange)">*</span>
        </label>
        <textarea
          class="form-textarea"
          id="message"
          name="message"
          rows="5"
          required
          placeholder="Tell us what you're interested in, what truck you drive, how you travel..."
        ></textarea>
      </div>

      <div class="form-row">
        <div class="form-field">
          <label class="form-label" for="callbackDate">When should we call you? (Date)</label>
          <input
            class="form-input"
            type="date"
            id="callbackDate"
            name="callback_date"
            autocomplete="off"
          />
        </div>
        <div class="form-field">
          <label class="form-label" for="callbackTime">Preferred call-back time</label>
          <input
            class="form-input"
            type="time"
            id="callbackTime"
            name="callback_time"
            autocomplete="off"
          />
        </div>
      </div>

      <div class="form-field">
        <label class="form-label" for="referralSourceSelfReported">
          How did you hear about us? <span aria-hidden="true" style="color:var(--orange)">*</span>
        </label>
        <select
          class="form-input"
          id="referralSourceSelfReported"
          name="referral_source_self_reported"
          required
          style="cursor: pointer"
        >
          <option value="" disabled selected>— Select an option —</option>
          <option value="Instagram">Instagram</option>
          <option value="Facebook">Facebook</option>
          <option value="TikTok">TikTok</option>
          <option value="YouTube">YouTube</option>
          <option value="Thabo and the Unimog">Thabo and the Unimog</option>
          <option value="Wheels and Wins YouTube channel">Wheels and Wins YouTube channel</option>
          <option value="Google Search">Google Search</option>
          <option value="Word of mouth">Word of mouth</option>
          <option value="Referred by Thabo Nel">Referred by Thabo Nel</option>
          <option value="Other">Other</option>
        </select>
      </div>

      <div class="form-field" id="referralOtherField" style="display: none">
        <label class="form-label" for="referralSourceOther">
          Please tell us where <span aria-hidden="true" style="color:var(--orange)">*</span>
        </label>
        <input
          class="form-input"
          type="text"
          id="referralSourceOther"
          name="referral_source_other"
          autocomplete="off"
          placeholder="Example: a friend, a show, a forum, another channel..."
        />
      </div>

      <button type="submit" class="btn-primary form-submit" style="margin-top: 1.5rem">
        Send Enquiry
      </button>
      <p id="formStatus" style="margin-top: 1rem; color: var(--muted); font-size: 0.85rem" aria-live="polite"></p>
    </form>

    <div style="margin-top: 4rem; padding-top: 3rem; border-top: 1px solid var(--border)">
      <p style="font-size: 0.82rem; color: var(--muted); margin-bottom: 0.5rem">Prefer to call?</p>
      <a href="tel:+61430863819" style="font-family: var(--font-heading); font-size: 1.8rem; color: var(--orange); text-decoration: none; letter-spacing: 0.05em">
        0430 863 819
      </a>
      <p style="font-size: 0.82rem; color: var(--muted); margin-top: 1rem">
        77 Coleyville Rd, Mutdapilly QLD 4307
      </p>
    </div>
  </section>
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const productSlug = params.get('product');
  const productName = params.get('name');
  const intent = params.get('intent');
  const message = params.get('message');

  const msgField = document.getElementById('message') as HTMLTextAreaElement | null;
  const hiddenField = document.getElementById('productInterestField') as HTMLInputElement | null;
  const intentField = document.getElementById('intentField') as HTMLInputElement | null;

  const displayName = productName
    ? decodeURIComponent(productName)
    : productSlug
      ? decodeURIComponent(productSlug).replace(/-/g, ' ')
      : null;

  if (message && msgField) {
    msgField.value = message;
    msgField.focus();
    msgField.setSelectionRange(message.length, message.length);
  } else if (displayName && msgField) {
    const prefix = intent === 'buy'
      ? `I'd like to purchase the ${displayName}. `
      : intent === 'register'
        ? `I'd like to register my interest in the ${displayName}. `
        : `I'm interested in the ${displayName}. `;
    msgField.value = prefix;
    msgField.focus();
    msgField.setSelectionRange(prefix.length, prefix.length);
  }
  if (productSlug && hiddenField) hiddenField.value = decodeURIComponent(productSlug);
  if (intent && intentField) intentField.value = intent;

  const referralSource = document.getElementById('referralSourceSelfReported') as HTMLSelectElement | null;
  const referralOtherField = document.getElementById('referralOtherField') as HTMLDivElement | null;
  const referralOther = document.getElementById('referralSourceOther') as HTMLInputElement | null;

  function syncReferralOther() {
    const isOther = referralSource?.value === 'Other';
    if (referralOtherField) referralOtherField.style.display = isOther ? 'block' : 'none';
    if (referralOther) {
      referralOther.required = Boolean(isOther);
      if (!isOther) referralOther.value = '';
    }
  }

  referralSource?.addEventListener('change', syncReferralOther);
  syncReferralOther();

  (function() {
    function setField(id: string, value: string) {
      const el = document.getElementById(id) as HTMLInputElement | null;
      if (el && value) el.value = value;
    }

    try {
      const raw = localStorage.getItem('brv_referral');
      if (raw) {
        const referral = JSON.parse(raw) as {
          ref: string; entry_page: string; first_touch: string;
          utm_source: string; utm_campaign: string; expires: number;
        };
        if (referral.expires > Date.now()) {
          setField('referralPartner', referral.ref);
          setField('referralEntryPage', referral.entry_page);
          setField('referralFirstTouch', referral.first_touch);
          setField('referralUtmSource', referral.utm_source);
          setField('referralUtmCampaign', referral.utm_campaign);
        }
      }
    } catch {}

    try {
      const partnerField = document.getElementById('referralPartner') as HTMLInputElement | null;
      if (!partnerField?.value) {
        const raw = localStorage.getItem('brv_utm');
        if (raw) {
          const utm = JSON.parse(raw) as {
            utm_source: string; utm_campaign: string; entry_page: string;
          };
          setField('referralUtmSource', utm.utm_source);
          setField('referralUtmCampaign', utm.utm_campaign);
          setField('referralEntryPage', utm.entry_page);
        }
      }
    } catch {}
  })();

  const form = document.getElementById('enquiryForm') as HTMLFormElement | null;
  const status = document.getElementById('formStatus') as HTMLParagraphElement | null;

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const submit = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const formData = new FormData(form);
    const payload: Record<string, string> = {};
    formData.forEach((value, key) => {
      payload[key === 'bot-field' ? 'botField' : key] = String(value);
    });

    if (status) status.textContent = 'Sending enquiry...';
    if (submit) {
      submit.disabled = true;
      submit.textContent = 'Sending...';
    }

    try {
      const res = await fetch('/.netlify/functions/contact-submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json() as { error?: string };
      if (!res.ok) throw new Error(data.error ?? 'Could not send enquiry');
      window.location.href = '/inquiry-form/success/';
    } catch (err) {
      if (status) {
        status.textContent = err instanceof Error
          ? `${err.message}. You can still call us on 0430 863 819.`
          : 'Could not send enquiry. You can still call us on 0430 863 819.';
      }
      if (submit) {
        submit.disabled = false;
        submit.textContent = 'Send Enquiry';
      }
    }
  });
</script>
