---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { displayImageUrl } from '../../lib/media';

const pageUrl = 'https://beyondrv.com.au/caravan-towing-calculator/';
const heroImage = '/images/optimized/products/sunpatch-12c-couples-caravan/01-sunpatch-12c-couples-caravan-hero.webp';
const disclaimer = 'This tool provides an estimate only. Final suitability depends on your exact vehicle variant, compliance plate, manufacturer specifications, towbar rating, axle limits, tyre ratings, accessories, real loaded weights and certified weighbridge results. ByondRV must confirm final suitability before purchase.';

const faqs = [
  {
    q: 'Why can a vehicle with 3500kg towing capacity still be unsuitable?',
    a: 'Because towing capacity is only one limit. A vehicle can be under its braked towing capacity but still exceed GVM, GCM, tow ball download, towbar rating, axle limits or tyre ratings.'
  },
  {
    q: 'What is tow ball download?',
    a: 'Tow ball download is the weight the caravan places down onto the tow ball. It counts as load on the vehicle and reduces remaining payload.'
  },
  {
    q: 'Should I use ATM or GTM?',
    a: 'Use ATM to check the loaded caravan against the vehicle braked towing capacity. Use GTM, or a measured estimate of the weight on the caravan wheels when hitched, for the combined GCM check.'
  }
];

const products = [
  { name: 'Sunpatch 12C Couples Off-Road Van', url: 'https://beyondrv.com.au/sunpatch-12c-couples-caravan/', atm: '2420kg', ball: '160kg', fit: 'Compact couples van for buyers wanting a lighter towing setup.' },
  { name: 'Sunpatch 15-XC Couples Off-Road Van', url: 'https://beyondrv.com.au/sunpatch-15xc-couples-offroad-van/', atm: '2500kg', ball: 'Confirm with ByondRV', fit: 'Couples off-road van with more space while staying in a mid-weight towing discussion.' },
  { name: 'Sunpatch 19-XC Hardtop Couples Off-Road Van', url: 'https://beyondrv.com.au/sunpatch-19xc-hardtop-couples-offroad-van/', atm: 'Confirm with ByondRV', ball: 'Confirm with ByondRV', fit: 'Larger couples hardtop caravan requiring careful tow vehicle matching.' },
  { name: 'Sunpatch 21-XF Hardtop Family Off-Road Van', url: 'https://beyondrv.com.au/sunpatch-21xf-hardtop-family-offroad-van/', atm: 'Confirm with ByondRV', ball: 'Confirm with ByondRV', fit: 'Family layout requiring the strongest towing and payload checks.' }
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Caravan Towing Calculator',
    url: pageUrl,
    description: 'Manual Australian caravan towing calculator for GVM, GCM, braked towing capacity, tow ball download, ATM, GTM, payload and luggage.'
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map(item => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a }
    }))
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://beyondrv.com.au/' },
      { '@type': 'ListItem', position: 2, name: 'Vehicle Suitability Checker', item: 'https://beyondrv.com.au/vehicle-suitability-checker/' },
      { '@type': 'ListItem', position: 3, name: 'Caravan Towing Calculator', item: pageUrl }
    ]
  },
  ...products.map(product => ({
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: product.name,
    url: product.url,
    brand: { '@type': 'Brand', name: 'ByondRV' },
    category: 'Off-road caravan'
  }))
];
---
<BaseLayout
  title="Caravan Towing Calculator | ByondRV"
  description="Estimate whether your tow vehicle may be a candidate for a ByondRV caravan using GVM, GCM, braked towing capacity, tow ball download, ATM, GTM and payload."
  image={heroImage}
  activePath="/vehicle-suitability-checker/"
  structuredData={schema}
>
  <section class="page-hero page-hero--short">
    <div class="page-hero-bg" style={`background-image: url('${displayImageUrl(heroImage, 1600)}')`}></div>
    <div class="hero-overlay"></div>
    <div class="hero-overlay-bottom"></div>
    <div class="page-hero-content">
      <div class="section-eyebrow">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-text">Caravan Towing Calculator</span>
      </div>
      <h1 class="hero-title">Can Your Vehicle Tow It?</h1>
      <p class="hero-sub">
        Estimate GVM, GCM, tow capacity, tow ball download and caravan payload before choosing a ByondRV off-road caravan.
      </p>
    </div>
  </section>

  <section class="container checker-layout">
    <div class="checker-panel">
      <form class="checker-form" id="towCalculator">
        <div class="form-field form-field--full">
          <label class="form-label" for="vehicleName">Vehicle</label>
          <input class="form-input" id="vehicleName" type="text" placeholder="Example: Toyota LandCruiser 300" />
        </div>
        <div class="form-field">
          <label class="form-label" for="gvm">Vehicle GVM (kg)</label>
          <input class="form-input" id="gvm" type="number" min="0" placeholder="3280" />
        </div>
        <div class="form-field">
          <label class="form-label" for="gcm">Vehicle GCM (kg)</label>
          <input class="form-input" id="gcm" type="number" min="0" placeholder="6750" />
        </div>
        <div class="form-field">
          <label class="form-label" for="currentWeight">Current vehicle weight before listed additions (kg)</label>
          <input class="form-input" id="currentWeight" type="number" min="0" placeholder="2500" />
          <span class="form-help">Use a current weighbridge weight if possible. If it already includes accessories, luggage or passengers, enter 0 for those items below.</span>
        </div>
        <div class="form-field">
          <label class="form-label" for="towCapacity">Braked towing capacity or towbar limit (kg)</label>
          <input class="form-input" id="towCapacity" type="number" min="0" placeholder="3500" />
          <span class="form-help">Enter the lower figure if your towbar rating is lower than the vehicle braked towing capacity.</span>
        </div>
        <div class="form-field">
          <label class="form-label" for="towBallLimit">Tow ball or towbar ball limit (kg)</label>
          <input class="form-input" id="towBallLimit" type="number" min="0" placeholder="350" />
        </div>
        <div class="form-field">
          <label class="form-label" for="ballDownload">Estimated tow ball download (kg)</label>
          <input class="form-input" id="ballDownload" type="number" min="0" placeholder="160" />
        </div>
        <div class="form-field">
          <label class="form-label" for="atm">Caravan ATM rating (kg)</label>
          <input class="form-input" id="atm" type="number" min="0" placeholder="2420" />
        </div>
        <div class="form-field">
          <label class="form-label" for="loadedCaravan">Estimated actual loaded caravan weight (kg)</label>
          <input class="form-input" id="loadedCaravan" type="number" min="0" placeholder="2300" />
        </div>
        <div class="form-field">
          <label class="form-label" for="gtm">Caravan GTM rating (kg)</label>
          <input class="form-input" id="gtm" type="number" min="0" placeholder="2260" />
        </div>
        <div class="form-field">
          <label class="form-label" for="passengers">Passengers in vehicle (kg)</label>
          <input class="form-input" id="passengers" type="number" min="0" placeholder="180" />
        </div>
        <div class="form-field">
          <label class="form-label" for="accessories">Vehicle accessories (kg)</label>
          <input class="form-input" id="accessories" type="number" min="0" placeholder="80" />
        </div>
        <div class="form-field form-field--full">
          <label class="form-label" for="luggage">Vehicle luggage and touring gear (kg)</label>
          <input class="form-input" id="luggage" type="number" min="0" placeholder="80" />
        </div>
      </form>
      <p class="calculator-disclaimer">{disclaimer}</p>
    </div>

    <aside class="result-panel" id="resultPanel" data-status="neutral" aria-live="polite">
      <div class="result-status" id="statusLabel">Enter your numbers to calculate a result.</div>
      <h2 id="resultTitle">Enter your numbers</h2>
      <p class="result-summary" id="resultSummary">Enter your numbers to calculate a result.</p>
      <div class="result-metrics">
        <div class="result-metric"><span>Available payload</span><strong id="availablePayload">0 kg</strong></div>
        <div class="result-metric"><span>Estimated loaded vehicle weight</span><strong id="loadedVehicle">0 kg</strong></div>
        <div class="result-metric"><span>Remaining GVM margin</span><strong id="gvmMargin">0 kg</strong></div>
        <div class="result-metric"><span>Remaining GCM margin</span><strong id="gcmMargin">0 kg</strong></div>
        <div class="result-metric"><span>Tow capacity margin</span><strong id="towMargin">0 kg</strong></div>
        <div class="result-metric"><span>ATM margin</span><strong id="atmMargin">0 kg</strong></div>
        <div class="result-metric"><span>Estimated caravan axle load</span><strong id="caravanAxleLoad">0 kg</strong></div>
        <div class="result-metric"><span>GTM margin</span><strong id="gtmMargin">0 kg</strong></div>
        <div class="result-metric"><span>Tow ball margin</span><strong id="ballMargin">0 kg</strong></div>
        <div class="result-metric"><span>Data quality</span><strong id="dataQuality">Needs review</strong></div>
      </div>
      <div class="result-recommendation">
        <strong>ByondRV product recommendation</strong>
        <p id="recommendation">Confirm with ByondRV</p>
      </div>
      <ul class="result-notes" id="warningNotes"></ul>
      <a class="btn-primary" id="sendResult" href="/inquiry-form/?intent=vehicle-suitability">Send this result to ByondRV</a>
    </aside>
  </section>

  <section class="authority-section authority-section--dark">
    <div class="container authority-copy">
      <h2>How this caravan towing calculator works</h2>
      <p>
        The calculator treats tow ball download as load on the vehicle, checks the vehicle against GVM, checks combined loaded vehicle and loaded caravan weight against GCM, compares actual loaded caravan weight against ATM and braked towing capacity, checks estimated caravan axle load against GTM, and compares ball download against the entered ball limit.
      </p>
      <div class="worked-example">
        <h3>Worked example</h3>
        <p>A vehicle weighing 2700kg before passengers and luggage may look strong with 3500kg towing capacity. Add 180kg of passengers, 120kg of accessories, 120kg of luggage and 240kg tow ball download and the loaded vehicle becomes 3360kg. If GVM is 3280kg, the result is red even if the caravan ATM is under the braked towing rating.</p>
      </div>
      <h2>ByondRV caravan product data table</h2>
      <div class="authority-table-wrap">
        <table class="authority-table">
          <thead>
            <tr>
              <th>Product</th>
              <th>Listed ATM / ball guide</th>
              <th>Data status</th>
            </tr>
          </thead>
          <tbody>
            {products.map(product => (
              <tr>
                <td><a href={new URL(product.url).pathname}>{product.name}</a></td>
                <td>ATM: {product.atm}<br />Ball: {product.ball}</td>
                <td>Confirm with ByondRV</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="container authority-section">
    <div class="authority-copy">
      <h2>Caravan towing FAQ</h2>
      <div class="faq-list">
        {faqs.map(item => (
          <details>
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { calculateCaravanSuitability } from '../../lib/vehicleSuitabilityCalculator.js';

  const form = document.getElementById('towCalculator');
  const resultPanel = document.getElementById('resultPanel');
  const fields = ['vehicleName', 'gvm', 'gcm', 'currentWeight', 'towCapacity', 'towBallLimit', 'ballDownload', 'atm', 'loadedCaravan', 'gtm', 'passengers', 'accessories', 'luggage'];
  let hasStarted = false;
  const byId = (id: string) => document.getElementById(id);
  const inputById = (id: string) => document.getElementById(id) as HTMLInputElement | null;
  const value = (id: string) => inputById(id)?.value ?? '';
  const fmt = (value: number) => `${Math.round(value).toLocaleString()} kg`;
  type CaravanResultValues = {
    availablePayload?: number;
    estimatedLoadedVehicleWeight?: number;
    remainingGvmMargin?: number;
    remainingGcmMargin?: number;
    towCapacityMargin?: number;
    atmMargin?: number;
    estimatedCaravanAxleLoad?: number;
    gtmMargin?: number;
    towBallMargin?: number;
  };
  const kgOrZero = (value?: number) => value === undefined ? '0 kg' : fmt(value);
  const kgOrNotCalculated = (value?: number) => value === undefined ? 'Not calculated' : fmt(value);

  function setText(id: string, value: string) {
    const el = byId(id);
    if (el) el.textContent = value;
  }

  function setNotes(notes: string[]) {
    const warningNotes = byId('warningNotes');
    if (warningNotes) warningNotes.innerHTML = notes.map((note: string) => `<li>${note}</li>`).join('');
  }

  function calculateTow() {
    const vehicleName = inputById('vehicleName')?.value || 'your vehicle';
    const result = calculateCaravanSuitability({
      vehicleGvm: value('gvm'),
      vehicleGcm: value('gcm'),
      currentVehicleWeight: value('currentWeight'),
      vehicleBrakedTowingCapacity: value('towCapacity'),
      vehicleTowBallLimit: value('towBallLimit'),
      estimatedTowBallDownload: value('ballDownload'),
      caravanAtmRating: value('atm'),
      estimatedActualLoadedCaravanWeight: value('loadedCaravan'),
      caravanGtmRating: value('gtm'),
      passengerWeight: value('passengers'),
      accessoryWeight: value('accessories'),
      luggageWeight: value('luggage')
    }, { started: hasStarted });
    const values: CaravanResultValues = 'values' in result ? result.values : {};

    resultPanel?.setAttribute('data-status', result.status);
    setText('statusLabel', result.statusLabel);
    setText('resultTitle', result.title);
    setText('resultSummary', result.summary);
    setText('availablePayload', kgOrZero(values.availablePayload));
    setText('loadedVehicle', kgOrZero(values.estimatedLoadedVehicleWeight));
    setText('gvmMargin', kgOrZero(values.remainingGvmMargin));
    setText('gcmMargin', kgOrZero(values.remainingGcmMargin));
    setText('towMargin', kgOrZero(values.towCapacityMargin));
    setText('atmMargin', kgOrZero(values.atmMargin));
    setText('caravanAxleLoad', kgOrZero(values.estimatedCaravanAxleLoad));
    setText('gtmMargin', kgOrZero(values.gtmMargin));
    setText('ballMargin', kgOrZero(values.towBallMargin));
    setText('dataQuality', result.dataQuality);
    setText('recommendation', result.recommendation);
    setNotes(result.notes);

    const message = [
      'Vehicle Suitability Checker result - caravan towing',
      `Vehicle: ${vehicleName}`,
      `Status: ${result.statusLabel}`,
      `Available payload: ${kgOrNotCalculated(values.availablePayload)}`,
      `Estimated loaded vehicle weight: ${kgOrNotCalculated(values.estimatedLoadedVehicleWeight)}`,
      `Remaining GVM margin: ${kgOrNotCalculated(values.remainingGvmMargin)}`,
      `Remaining GCM margin: ${kgOrNotCalculated(values.remainingGcmMargin)}`,
      `Tow capacity margin: ${kgOrNotCalculated(values.towCapacityMargin)}`,
      `ATM margin: ${kgOrNotCalculated(values.atmMargin)}`,
      `Estimated caravan axle load: ${kgOrNotCalculated(values.estimatedCaravanAxleLoad)}`,
      `GTM margin: ${kgOrNotCalculated(values.gtmMargin)}`,
      `Tow ball margin: ${kgOrNotCalculated(values.towBallMargin)}`,
      `Data quality: ${result.dataQuality}`,
      `Recommendation: ${result.recommendation}`
    ].join('\n');
    const send = byId('sendResult');
    if (send) send.setAttribute('href', `/inquiry-form/?intent=vehicle-suitability&message=${encodeURIComponent(message)}&fit_check_summary=${encodeURIComponent(message)}`);
  }

  fields.forEach(id => byId(id)?.addEventListener('input', () => {
    hasStarted = true;
    calculateTow();
  }));
  form?.addEventListener('submit', (event) => event.preventDefault());
</script>
