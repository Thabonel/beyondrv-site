---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { displayImageUrl, imageSrcSet } from '../../lib/media';
import { buildProductOffer } from '../../lib/structuredData.js';

const products = (await getCollection('products'))
  .filter(p => p.data.category === 'expedition');
type ProductEntry = typeof products[number];
const isProduct = (product: ProductEntry | undefined): product is ProductEntry => Boolean(product);

const unimogProducts = products.filter(p => p.slug.includes('unimog'));
const truckBuildOrder = [
  'expedition/3-5m-electric-poptop-cabover-family-camper',
  'expedition/4-7m-hardtop-truck-camper',
  '3-5m-poptop-truck-camper',
  '3-5m-diy-camper-box-with-cabover-and-underfloor-storage',
  'mercedes-sprinter-motorhome',
];
const truckBuildProducts = truckBuildOrder
  .map(slug => products.find(p => p.slug === slug))
  .filter(isProduct);

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Beyond RV Expedition Vehicles",
  "url": "https://beyondrv.com.au/expedition/",
  "hasPart": products.map(p => {
    const productUrl = `https://beyondrv.com.au/${p.slug}/`;
    return {
      "@type": "Product",
      "name": p.data.title,
      "url": productUrl,
      "offers": buildProductOffer({ price: p.data.price, status: p.data.status, url: productUrl })
    };
  })
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What platforms suit an expedition camper?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Common expedition camper platforms include Mercedes-Benz Unimog, Isuzu NPS, Iveco Daily 4x4, and other trucks with suitable payload and off-road capability."
      }
    },
    {
      "@type": "Question",
      "name": "Why choose a truck camper instead of a caravan?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A truck camper keeps the living body on the vehicle, which can improve manoeuvrability, departure angle, and access to tighter or rougher tracks compared with towing."
      }
    }
  ]
};
const heroImage = '/images/site/expedition-hero.webp';
const calloutImage = '/images/optimized/products/expedition/4-7m-hardtop-truck-camper/01-expedition-4-7m-hardtop-truck-camper-hero.webp';
---
<BaseLayout
  title="Expedition Vehicles | Unimog & Isuzu Campers | Beyond RV Queensland"
  description="Beyond RV builds expedition campers, 4x4 truck campers, Unimog bodies, and Isuzu NPS builds for serious Australian touring. Custom-built in Queensland."
  image={heroImage}
  activePath="/expedition/"
  structuredData={[schema, faqSchema]}
>
  <section class="page-hero">
    <div class="page-hero-bg" style={`background-image: url('${displayImageUrl(heroImage, 1600)}')`}></div>
    <div class="hero-overlay"></div>
    <div class="hero-overlay-bottom"></div>
    <div class="page-hero-content">
      <div class="section-eyebrow">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-text">Expedition Vehicles</span>
      </div>
      <h1 class="hero-title">Expedition<br><span class="accent">Range</span></h1>
      <p class="hero-sub">
        Built for people who go beyond. 4x4 truck campers, Unimog bodies and Isuzu NPS builds with full composite expedition bodies.
        Custom-built in Queensland for serious overlanders.
      </p>
    </div>
  </section>

  <!-- Builder credibility block -->
  <section class="expedition-callout container" style="margin-top: 5rem">
    <div>
      <div class="section-eyebrow reveal">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-text">Built by People Who Use Them</span>
      </div>
      <h2 class="section-title reveal reveal-delay-1">We build what<br>we actually drive.</h2>
      <p style="color: var(--muted); font-size: 0.95rem; line-height: 1.8; max-width: 480px; margin-top: 1rem;" class="reveal reveal-delay-2">
        Beyond RV's expedition range is designed by builders who spend time in the field.
        Every build is custom — we work with you from chassis selection through to final handover.
      </p>
    </div>
    <div class="expedition-callout-image reveal reveal-delay-2">
      <img
        src={displayImageUrl(calloutImage, 1200)}
        srcset={imageSrcSet(calloutImage)}
        sizes="(max-width: 900px) 100vw, 50vw"
        alt="Beyond RV 4.7m hardtop truck camper"
        loading="lazy"
        decoding="async"
      />
    </div>
  </section>

  <!-- Unimog range -->
  {unimogProducts.length > 0 && (
    <section class="container" style="margin-top: 5rem">
      <h2 class="section-title">Unimog Builds</h2>
      <p class="section-sub">Mercedes-Benz Unimog — the benchmark for extreme-terrain expedition vehicles.</p>
      <div class="product-grid">
        {unimogProducts.map(p => (
          <ProductCard
            title={p.data.title}
            slug={p.slug}
            category={p.data.category}
            tagline={p.data.tagline}
            price={p.data.price}
            status={p.data.status}
            heroImage={p.data.heroImage}
            priceBadge={p.data.priceBadge}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Truck builds -->
  {truckBuildProducts.length > 0 && (
    <section class="container" style="margin-top: 3rem; padding-bottom: 5rem">
      <h2 class="section-title">4x4 Truck Builds</h2>
      <p class="section-sub">Truck campers for couples and families, including the 4.7m hardtop camper that can be made to suit a Unimog.</p>
      <div class="product-grid">
        {truckBuildProducts.map(p => (
          <ProductCard
            title={p.data.title}
            slug={p.slug}
            category={p.data.category}
            tagline={p.data.tagline}
            price={p.data.price}
            status={p.data.status}
            heroImage={p.data.heroImage}
            priceBadge={p.data.priceBadge}
          />
        ))}
      </div>
    </section>
  )}

  <section class="container" style="padding-bottom: 5rem">
    <div class="page-content">
      <h2>Expedition campers for serious travel</h2>
      <h3>Which platforms work best?</h3>
      <p>
        Unimog, Isuzu NPS, Sprinter and similar truck platforms are common choices because they offer real payload, ground clearance,
        and off-road capability. The best platform depends on serviceability, payload, budget, and how remote
        you plan to travel.
      </p>
      <h3>Truck camper or caravan?</h3>
      <p>
        A truck camper keeps the camper body on the vehicle, which helps on tight, rough, or steep tracks.
        A caravan can suit touring routes where towing access, camp setup, and separation from the tow vehicle
        are more important.
      </p>
      <p>
        If you are comparing an Isuzu, Unimog, Sprinter, Iveco or other truck platform, send the details through the
        <a href="/inquiry-form/?product=expedition-custom">expedition enquiry form</a>.
      </p>
    </div>
  </section>

  <section class="cta-section">
    <div class="cta-bg" style="background-image: url('/images/site/mog2.jpg')"></div>
    <div class="cta-overlay"></div>
    <div class="cta-content">
      <h2 class="cta-title reveal">Every expedition<br>build is <span class="italic">custom.</span></h2>
      <p class="cta-sub reveal reveal-delay-1">
        Tell us your platform, your mission, and your timeline. We'll design around your reality.
      </p>
      <div class="cta-actions reveal reveal-delay-2">
        <a href="/inquiry-form/?product=expedition-custom" class="btn-primary">Start Your Build</a>
        <a href="tel:+61430863819" class="btn-ghost">Call 0430 863 819</a>
      </div>
    </div>
  </section>
</BaseLayout>
