---
interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'product';
  noIndex?: boolean;
  canonicalUrl?: string;
  structuredData?: object | object[];
  preloadImage?: {
    src: string;
    srcset?: string;
    sizes?: string;
  };
}
const {
  title,
  description,
  image = '/images/site/unimog-hero.jpg',
  type = 'website',
  noIndex = false,
  canonicalUrl,
  structuredData,
  preloadImage,
} = Astro.props;
const siteUrl = Astro.site ?? new URL('https://beyondrv.com.au');
const canonical = canonicalUrl ? new URL(canonicalUrl, siteUrl).toString() : new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = new URL(image, siteUrl).toString();
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "AutomotiveBusiness"],
  "@id": "https://beyondrv.com.au/#business",
  "name": "Beyond RV",
  "alternateName": "Beyond Caravans",
  "url": "https://beyondrv.com.au/",
  "logo": "https://beyondrv.com.au/images/site/admin-logo.png",
  "image": "https://beyondrv.com.au/images/site/unimog-hero.jpg",
  "telephone": "+61430863819",
  "email": "beyondcaravans@gmail.com",
  "priceRange": "$$",
  "description": "Queensland builder of slide-on campers, truck campers, off-road caravans, and expedition vehicle bodies.",
  "sameAs": [
    "https://www.youtube.com/@beyondrvcampers4129",
    "https://www.facebook.com/BeyondCaravans",
    "https://www.instagram.com/beyondrvaus/"
  ],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "77 Coleyville Rd",
    "addressLocality": "Mutdapilly",
    "addressRegion": "QLD",
    "postalCode": "4307",
    "addressCountry": "AU"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -27.66,
    "longitude": 152.55
  },
  "areaServed": [
    { "@type": "Country", "name": "Australia" },
    { "@type": "State", "name": "Queensland" },
    { "@type": "City", "name": "Brisbane" }
  ],
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    "opens": "09:00",
    "closes": "17:00",
    "description": "Workshop viewings by appointment."
  }]
};
---
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
{noIndex && <meta name="robots" content="noindex, nofollow" />}
<link rel="canonical" href={canonical} />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
<link rel="icon" type="image/png" href="/favicon-192.png" sizes="192x192" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
{preloadImage && (
  <link
    rel="preload"
    as="image"
    href={preloadImage.src}
    imagesrcset={preloadImage.srcset}
    imagesizes={preloadImage.sizes}
  />
)}

<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content="Beyond RV" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600&family=Playfair+Display:ital,wght@1,400;1,600&display=swap"
  rel="preload"
  as="style"
/>
<link
  href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600&family=Playfair+Display:ital,wght@1,400;1,600&display=swap"
  rel="stylesheet"
  media="print"
  onload="this.onload=null;this.media='all'"
/>
<noscript>
  <link
    href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600&family=Playfair+Display:ital,wght@1,400;1,600&display=swap"
    rel="stylesheet"
  />
</noscript>

{structuredData && (
  <script is:inline type="application/ld+json" set:html={JSON.stringify(
    Array.isArray(structuredData) ? structuredData : [structuredData]
  )} />
)}

<script is:inline type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
