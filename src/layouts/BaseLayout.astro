---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import CookieConsent from '../components/CookieConsent';
import PostHogProvider from '../components/PostHogProvider';
import SiteChatWidget from '../components/SiteChatWidget';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'product';
  noIndex?: boolean;
  canonicalUrl?: string;
  structuredData?: object | object[];
  preloadImage?: {
    src: string;
    srcset?: string;
    sizes?: string;
  };
  activePath?: string;
  productTitle?: string;
  productSlug?: string;
}
const { activePath = '', productTitle, productSlug, ...headProps } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <BaseHead {...headProps} />
</head>
<body>
  <div id="cursor" aria-hidden="true"></div>
  <div id="cursor-ring" aria-hidden="true"></div>

  <Header activePath={activePath} />

  <main id="main-content">
    <slot />
  </main>

  <Footer />

  <script>
    (function() {
      const params = new URLSearchParams(window.location.search);
      const ref = params.get('ref');
      const utmSource = params.get('utm_source');
      const utmMedium = params.get('utm_medium');
      const utmCampaign = params.get('utm_campaign');
      const THIRTY_DAYS = 30 * 24 * 60 * 60 * 1000;

      if (ref) {
        let existing: { ref: string; expires: number } | null = null;
        try { existing = JSON.parse(localStorage.getItem('brv_referral') || 'null'); } catch {}
        const isValid = existing && existing.expires > Date.now();
        if (!isValid) {
          localStorage.setItem('brv_referral', JSON.stringify({
            ref,
            entry_page: window.location.pathname,
            first_touch: new Date().toISOString(),
            utm_source: utmSource || '',
            utm_medium: utmMedium || '',
            utm_campaign: utmCampaign || '',
            expires: Date.now() + THIRTY_DAYS,
          }));
        }
      }

      if (!ref && utmSource) {
        localStorage.setItem('brv_utm', JSON.stringify({
          utm_source: utmSource,
          utm_medium: utmMedium || '',
          utm_campaign: utmCampaign || '',
          entry_page: window.location.pathname,
          stored_at: new Date().toISOString(),
        }));
      }
    })();
  </script>

  <CookieConsent client:load />
  <PostHogProvider client:load />
  <SiteChatWidget client:load pageTitle={headProps.title} productSlug={productSlug} productName={productTitle} />

  <script>
    const cursor = document.getElementById('cursor');
    const ring = document.getElementById('cursor-ring');
    if (cursor && ring && !window.matchMedia('(pointer: coarse)').matches) {
      const cursorEl = cursor;
      const ringEl = ring;
      let mx = 0, my = 0, rx = 0, ry = 0;
      document.addEventListener('mousemove', (e) => { mx = e.clientX; my = e.clientY; }, { passive: true });
      function animCursor() {
        cursorEl.style.left = mx + 'px';
        cursorEl.style.top = my + 'px';
        rx += (mx - rx) * 0.12;
        ry += (my - ry) * 0.12;
        ringEl.style.left = rx + 'px';
        ringEl.style.top = ry + 'px';
        requestAnimationFrame(animCursor);
      }
      animCursor();
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>
</body>
</html>
