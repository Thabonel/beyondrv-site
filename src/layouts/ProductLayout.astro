---
import BaseLayout from './BaseLayout.astro';
import OptionalExtras from '../components/OptionalExtras';
import type { CollectionEntry } from 'astro:content';
import { displayImageUrl, imageSrcSet, thumbImageUrl } from '../lib/media';
import { normalizeVideoUploadDate } from '../lib/structuredData.js';

type ProductData = CollectionEntry<'products'>['data'];
type ProductCategory = ProductData['category'];
type SpecRow = ProductData['keySpecs'][number];
type SpecGroup = NonNullable<ProductData['specGroups']>[number];
type Feature = NonNullable<ProductData['features']>[number];
type FaqItem = NonNullable<ProductData['faq']>[number];
type YoutubeVideo = NonNullable<ProductData['youtubeVideo']>;

interface Props {
  product: CollectionEntry<'products'>;
}
const { product } = Astro.props as Props;
const { data } = product;
const isComingSoon = data.status === 'coming-soon';
const encodedSlug = encodeURIComponent(product.slug);
const encodedName = encodeURIComponent(data.title);
const enquiryUrl = `/inquiry-form/?product=${encodedSlug}&name=${encodedName}`;
const siteUrl = Astro.site ?? new URL('https://beyondrv.com.au');
const productUrl = new URL(`/${product.slug}/`, siteUrl).toString();
const heroDisplayImage = displayImageUrl(data.heroImage, 1400);
const heroSrcSet = imageSrcSet(data.heroImage);
const heroSizes = '(max-width: 900px) 100vw, 58vw';
const galleryImages = [data.heroImage, ...data.gallery].map((img) => ({
  original: img,
  display: displayImageUrl(img, 1400),
  thumb: thumbImageUrl(img),
  srcset: imageSrcSet(img),
}));
const productImages = [data.heroImage, ...data.gallery]
  .filter(Boolean)
  .map((img) => new URL(img, siteUrl).toString());
const categoryBySlug: Record<ProductCategory, { name: string; url: string }> = {
  'slide-on': { name: 'Slide-On Campers', url: '/our-slide-on-campers/' },
  caravan: { name: 'Off-Road Caravans', url: '/our-caravans/' },
  expedition: { name: 'Expedition Vehicles', url: '/expedition/' },
};
const categoryMeta = categoryBySlug[data.category];
const youtubeVideo: YoutubeVideo | undefined = data.youtubeVideo;
const youtubeEmbedParams = new URLSearchParams({
  rel: '0',
  playsinline: '1',
});
if (youtubeVideo?.startSeconds) youtubeEmbedParams.set('start', String(youtubeVideo.startSeconds));
const youtubeEmbedUrl = youtubeVideo
  ? `https://www.youtube-nocookie.com/embed/${youtubeVideo.id}?${youtubeEmbedParams.toString()}`
  : '';
const youtubeWatchUrl = youtubeVideo
  ? `https://www.youtube.com/watch?v=${youtubeVideo.id}${youtubeVideo.startSeconds ? `&t=${youtubeVideo.startSeconds}s` : ''}`
  : '';
const youtubeThumbnail = youtubeVideo?.thumbnail
  ?? (youtubeVideo ? `https://i.ytimg.com/vi/${youtubeVideo.id}/maxresdefault.jpg` : '');
const youtubeUploadDate = normalizeVideoUploadDate(youtubeVideo?.uploadDate);
const activeSpecGroups = data.specGroups?.filter((g: SpecGroup) => g.items.length > 0) ?? [];

const priceNum = data.price.replace(/[^0-9.]/g, '');
function compactSku(slug: string) {
  const cleaned = slug.toUpperCase().replace(/[^A-Z0-9]+/g, '-').replace(/^-+|-+$/g, '');
  let hash = 0;
  for (const char of slug) hash = ((hash << 5) - hash + char.charCodeAt(0)) >>> 0;
  const suffix = hash.toString(36).toUpperCase().padStart(6, '0').slice(-6);
  const prefix = cleaned.slice(0, 21).replace(/-+$/g, '');
  return `BRV-${prefix}-${suffix}`;
}
const merchantReturnPolicy = {
  "@type": "MerchantReturnPolicy",
  "applicableCountry": "AU",
  "returnPolicyCategory": "https://schema.org/MerchantReturnNotPermitted"
};
const pickupShippingDetails = {
  "@type": "OfferShippingDetails",
  "shippingDestination": {
    "@type": "DefinedRegion",
    "addressCountry": "AU"
  },
  "shippingRate": {
    "@type": "MonetaryAmount",
    "value": "0",
    "currency": "AUD"
  },
  "deliveryTime": {
    "@type": "ShippingDeliveryTime",
    "handlingTime": {
      "@type": "QuantitativeValue",
      "minValue": 0,
      "maxValue": 0,
      "unitCode": "DAY"
    },
    "transitTime": {
      "@type": "QuantitativeValue",
      "minValue": 0,
      "maxValue": 0,
      "unitCode": "DAY"
    }
  },
  "shippingLabel": "Workshop pickup or delivery arranged directly with Beyond RV."
};
const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": `${productUrl}#product`,
  "name": data.title,
  "description": data.seoDesc ?? data.tagline,
  "url": productUrl,
  "sku": compactSku(product.slug),
  "brand": { "@type": "Brand", "name": "Beyond RV" },
  "manufacturer": { "@type": "Organization", "name": "Beyond RV", "url": "https://beyondrv.com.au/" },
  "image": productImages,
  "category": categoryMeta.name,
  "itemCondition": "https://schema.org/NewCondition",
  "areaServed": { "@type": "Country", "name": "Australia" },
  ...(priceNum && {
    "offers": {
      "@type": "Offer",
      "url": productUrl,
      "priceCurrency": "AUD",
      "price": priceNum,
      "priceValidUntil": "2026-12-31",
      "itemCondition": "https://schema.org/NewCondition",
      "availability": isComingSoon
        ? "https://schema.org/PreOrder"
        : "https://schema.org/InStock",
      "seller": {
        "@type": "Organization",
        "name": "Beyond RV",
        "url": "https://beyondrv.com.au/"
      },
      "areaServed": { "@type": "Country", "name": "Australia" },
      "hasMerchantReturnPolicy": merchantReturnPolicy,
      "shippingDetails": pickupShippingDetails
    }
  }),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://beyondrv.com.au/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": categoryMeta.name,
      "item": new URL(categoryMeta.url, siteUrl).toString()
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": data.title,
      "item": productUrl
    }
  ]
};

const faqSchema = data.faq && data.faq.length > 0
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": data.faq.map(({ q, a }: FaqItem) => ({
        "@type": "Question",
        "name": q,
        "acceptedAnswer": { "@type": "Answer", "text": a }
      }))
    }
  : undefined;

const videoSchema = youtubeVideo
  ? {
      "@context": "https://schema.org",
      "@type": "VideoObject",
      "@id": `${productUrl}#video`,
      "name": youtubeVideo.title,
      "description": youtubeVideo.description ?? data.seoDesc ?? data.tagline,
      "thumbnailUrl": youtubeThumbnail,
      "uploadDate": youtubeUploadDate,
      ...(youtubeVideo.duration && { "duration": youtubeVideo.duration }),
      "embedUrl": youtubeEmbedUrl,
      "contentUrl": youtubeWatchUrl,
      "publisher": {
        "@type": "Organization",
        "name": "Beyond RV",
        "logo": {
          "@type": "ImageObject",
          "url": "https://beyondrv.com.au/images/site/admin-logo.png"
        }
      }
    }
  : undefined;

const schemas = [productSchema, breadcrumbSchema, ...(faqSchema ? [faqSchema] : []), ...(videoSchema ? [videoSchema] : [])];
---
<BaseLayout
  title={data.seoTitle ?? `${data.title} | Beyond RV`}
  description={data.seoDesc ?? data.tagline}
  image={data.heroImage}
  type="product"
  canonicalUrl={data.canonicalUrl}
  structuredData={schemas}
  preloadImage={{ src: heroDisplayImage, srcset: heroSrcSet, sizes: heroSizes }}
  activePath={`/${product.slug}/`}
  productTitle={data.title}
  productSlug={product.slug}
>
  <section class="product-hero-section">
    <div class="product-gallery">
      <div class="product-gallery-main">
        <img
          id="productHeroImg"
          src={heroDisplayImage}
          srcset={heroSrcSet}
          sizes={heroSizes}
          alt={data.title}
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
        {galleryImages.length > 1 && (
          <div class="product-gallery-controls" aria-label={`${data.title} gallery navigation`}>
            <button class="gallery-nav-btn gallery-nav-prev" type="button" aria-label="Previous photo" data-gallery-prev>
              ‹
            </button>
            <span class="gallery-count" aria-live="polite">
              <span data-gallery-current>1</span> / {galleryImages.length}
            </span>
            <button class="gallery-nav-btn gallery-nav-next" type="button" aria-label="Next photo" data-gallery-next>
              ›
            </button>
          </div>
        )}
      </div>
      {data.gallery.length > 0 && (
        <div class="product-gallery-thumbs">
          {galleryImages.map((img, i) => (
            <button
              class={`thumb-btn${i === 0 ? ' active' : ''}`}
              data-src={img.display}
              data-srcset={img.srcset}
              aria-label={`View image ${i + 1} of ${data.title}`}
            >
              <img src={img.thumb} alt={`${data.title} — view ${i + 1}`} loading="lazy" decoding="async" />
            </button>
          ))}
        </div>
      )}
    </div>

    <div class="product-hero-info">
      <div class="section-eyebrow">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-text">{data.category}</span>
      </div>
      <h1 class="product-title">{data.title}</h1>
      <p class="product-tagline">{data.tagline}</p>

      <div class="product-price-block">
        {data.priceBadge && !isComingSoon && <span class="badge">{data.priceBadge}</span>}
        {isComingSoon && <span class="coming-soon-badge">Coming Soon</span>}
        <span class="product-price">{data.price}</span>
      </div>

      {data.keySpecs.length > 0 && (
        <div class="key-specs">
          {data.keySpecs.map((s: SpecRow) => (
            <div class="key-spec">
              <span class="key-spec-label">{s.label}</span>
              <span class="key-spec-value">{s.value}</span>
            </div>
          ))}
        </div>
      )}

      <div class="product-ctas">
        {isComingSoon ? (
          <a href={enquiryUrl + '&intent=register'} class="btn-primary">Register Interest</a>
        ) : (
          <>
            <a href={enquiryUrl} class="btn-primary">Enquire Now</a>
            <a href={enquiryUrl + '&intent=buy'} class="btn-ghost">Buy Now</a>
          </>
        )}
      </div>
    </div>
  </section>

  <section class="product-description container">
    <div class="product-description-body prose">
      <slot />
      <h2>Is this the right build for you?</h2>
      <p>
        This {data.category === 'caravan' ? 'off-road caravan' : data.category === 'expedition' ? 'expedition camper' : 'slide-on camper'} is best assessed against your vehicle, payload, travel style, and the terrain you expect to cover.
        If you are comparing sizes, tow weights, tray fitment, or custom options, start with the
        <a href={categoryMeta.url}>{categoryMeta.name.toLowerCase()}</a> range or send the team an
        <a href={enquiryUrl}>enquiry for this product</a>.
      </p>
    </div>
  </section>

  {youtubeVideo && (
    <section class="product-video-section container" id="walkthrough-video">
      <div class="section-eyebrow">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-text">Video Walkthrough</span>
      </div>
      <h2 class="section-title">Watch the walkthrough</h2>
      {(youtubeVideo.description || youtubeVideo.transcriptSummary) && (
        <p class="product-video-intro">
          {youtubeVideo.description ?? youtubeVideo.transcriptSummary}
        </p>
      )}
      <div class="product-video-frame">
        <iframe
          src={youtubeEmbedUrl}
          title={youtubeVideo.title}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
      {youtubeVideo.transcriptSummary && youtubeVideo.description && (
        <p class="product-video-summary">{youtubeVideo.transcriptSummary}</p>
      )}
      <div class="product-video-actions">
        <a href={enquiryUrl} class="btn-primary">Enquire About This Build</a>
      </div>
    </section>
  )}

  {activeSpecGroups.length > 0 && (
    <section class="product-specs-section container">
      <div class="specs-heading-row">
        <div>
          <div class="section-eyebrow">
            <div class="section-eyebrow-line"></div>
            <span class="section-eyebrow-text">Product Details</span>
          </div>
          <h2 class="section-title">Specifications</h2>
        </div>
        <div class="specs-actions" aria-label="Specification section controls">
          <button class="specs-toggle-btn" type="button" data-specs-expand>Expand all</button>
          <button class="specs-toggle-btn" type="button" data-specs-collapse>Collapse all</button>
        </div>
      </div>

      {data.keySpecs.length > 0 && (
        <div class="specs-summary-strip" aria-label={`${data.title} key specifications`}>
          {data.keySpecs.map((s: SpecRow) => (
            <div class="specs-summary-item">
              <span class="specs-summary-label">{s.label}</span>
              <span class="specs-summary-value">{s.value}</span>
            </div>
          ))}
        </div>
      )}

      <div class="spec-accordion">
        {activeSpecGroups.map((group: SpecGroup, index: number) => (
          <details class="spec-panel" open={index < 2}>
            <summary class="spec-panel-summary">
              <span>{group.group}</span>
              <span class="spec-panel-count">{group.items.length} specs</span>
            </summary>
            <dl class="spec-list">
              {group.items.map((row: SpecRow) => (
                <div class="spec-list-row">
                  <dt>{row.label}</dt>
                  <dd>{row.value}</dd>
                </div>
              ))}
            </dl>
          </details>
        ))}
      </div>
    </section>
  )}

  {(!data.specGroups || data.specGroups.length === 0) && data.specs && data.specs.length > 0 && (
    <section class="product-specs-section container">
      <div class="specs-heading-row">
        <div>
          <div class="section-eyebrow">
            <div class="section-eyebrow-line"></div>
            <span class="section-eyebrow-text">Product Details</span>
          </div>
          <h2 class="section-title">Specifications</h2>
        </div>
      </div>
      <div class="spec-accordion">
        <details class="spec-panel" open>
          <summary class="spec-panel-summary">
            <span>Full Specifications</span>
            <span class="spec-panel-count">{data.specs.length} specs</span>
          </summary>
          <dl class="spec-list">
          {data.specs.map((row: SpecRow) => (
            <div class="spec-list-row">
              <dt>{row.label}</dt>
              <dd>{row.value}</dd>
            </div>
          ))}
          </dl>
        </details>
      </div>
    </section>
  )}

  {!isComingSoon && (
    <OptionalExtras
      client:load
      basePrice={data.price}
      productSlug={product.slug}
      productName={data.title}
    />
  )}

  {data.features && data.features.length > 0 && (
    <section class="product-features-section container">
      <h2 class="section-title">Features</h2>
      <ul class="features-list">
        {data.features.map((f: Feature) => <li>{f}</li>)}
      </ul>
    </section>
  )}

  {data.faq && data.faq.length > 0 && (
    <section class="product-faq-section container">
      <h2 class="section-title">FAQ</h2>
      <div class="faq-list">
        {data.faq.map(({ q, a }: FaqItem, i: number) => (
          <div class="faq-item" id={`faq-${i}`}>
            <button class="faq-question" aria-expanded="false" aria-controls={`faq-answer-${i}`}>
              {q}
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id={`faq-answer-${i}`} role="region">
              <p>{a}</p>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="product-enquiry-band">
    <div class="container">
      <h2>Ready to make it yours?</h2>
      <p>
        Talk to the team — we're based in Mutdapilly, QLD, and we build every camper ourselves.
      </p>
      <div class="product-ctas">
        {isComingSoon ? (
          <a href={enquiryUrl + '&intent=register'} class="btn-primary">Register Interest</a>
        ) : (
          <>
            <a href={enquiryUrl} class="btn-primary">Enquire Now</a>
            <a href="tel:+61430863819" class="btn-ghost">Call 0430 863 819</a>
          </>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const heroImg = document.getElementById('productHeroImg') as HTMLImageElement | null;
  const thumbButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.thumb-btn'));
  const galleryCurrent = document.querySelector<HTMLElement>('[data-gallery-current]');
  let activeGalleryIndex = Math.max(0, thumbButtons.findIndex(btn => btn.classList.contains('active')));

  function showGalleryImage(index: number) {
    if (!heroImg || thumbButtons.length === 0) return;

    const nextIndex = (index + thumbButtons.length) % thumbButtons.length;
    const nextButton = thumbButtons[nextIndex];
    if (!nextButton?.dataset.src) return;

    heroImg.src = nextButton.dataset.src;
    if (nextButton.dataset.srcset) heroImg.srcset = nextButton.dataset.srcset;

    thumbButtons.forEach(btn => btn.classList.remove('active'));
    nextButton.classList.add('active');
    activeGalleryIndex = nextIndex;
    if (galleryCurrent) galleryCurrent.textContent = String(nextIndex + 1);
  }

  thumbButtons.forEach((btn, index) => {
    btn.addEventListener('click', () => showGalleryImage(index));
  });

  document.querySelector<HTMLButtonElement>('[data-gallery-prev]')?.addEventListener('click', () => {
    showGalleryImage(activeGalleryIndex - 1);
  });

  document.querySelector<HTMLButtonElement>('[data-gallery-next]')?.addEventListener('click', () => {
    showGalleryImage(activeGalleryIndex + 1);
  });

  document.querySelector<HTMLElement>('.product-gallery-main')?.addEventListener('keydown', event => {
    if (event.key === 'ArrowLeft') showGalleryImage(activeGalleryIndex - 1);
    if (event.key === 'ArrowRight') showGalleryImage(activeGalleryIndex + 1);
  });

  document.querySelectorAll<HTMLButtonElement>('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const isOpen = item?.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(el => {
        el.classList.remove('open');
        el.querySelector<HTMLButtonElement>('.faq-question')?.setAttribute('aria-expanded', 'false');
      });
      if (!isOpen && item) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  const specPanels = Array.from(document.querySelectorAll<HTMLDetailsElement>('.spec-panel'));
  document.querySelector<HTMLButtonElement>('[data-specs-expand]')?.addEventListener('click', () => {
    specPanels.forEach(panel => {
      panel.open = true;
    });
  });
  document.querySelector<HTMLButtonElement>('[data-specs-collapse]')?.addEventListener('click', () => {
    specPanels.forEach(panel => {
      panel.open = false;
    });
  });
</script>
