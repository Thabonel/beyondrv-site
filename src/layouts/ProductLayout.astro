---
import BaseLayout from './BaseLayout.astro';
import OptionalExtras from '../components/OptionalExtras';
import type { CollectionEntry } from 'astro:content';
import { displayImageUrl, imageSrcSet, thumbImageUrl } from '../lib/media';
import { parseMoneyValue } from '../lib/payment';
import { availabilityLabel, formatShopPrice, normalizeSaleLabel, sourceTypeLabel, availabilitySchema } from '../lib/shop';
import { getProductCheckoutOptions } from '../lib/checkout';
import { buildMerchantProduct, normalizeVideoUploadDate } from '../lib/structuredData.js';
import paymentSettings from '../data/payment-settings.json';

type ProductData = CollectionEntry<'products'>['data'];
type ProductCategory = ProductData['category'];
type SpecRow = ProductData['keySpecs'][number];
type SpecGroup = NonNullable<ProductData['specGroups']>[number];
type Feature = NonNullable<ProductData['features']>[number];
type FaqItem = NonNullable<ProductData['faq']>[number];
type YoutubeVideo = NonNullable<ProductData['youtubeVideo']>;
type SuitabilityData = NonNullable<ProductData['suitabilityData']>;

interface Props {
  product: CollectionEntry<'products'>;
}
const { product } = Astro.props as Props;
const { data } = product;
const encodedSlug = encodeURIComponent(product.slug);
const encodedName = encodeURIComponent(data.title);
const enquiryUrl = `/inquiry-form/?product=${encodedSlug}&name=${encodedName}`;
const siteUrl = Astro.site ?? new URL('https://beyondrv.com.au');
const productUrl = new URL(`/${product.slug}/`, siteUrl).toString();
const heroDisplayImage = displayImageUrl(data.heroImage, 1400);
const heroSrcSet = imageSrcSet(data.heroImage);
const heroSizes = '(max-width: 900px) 100vw, 58vw';
const galleryImages = [data.heroImage, ...data.gallery].map((img) => ({
  original: img,
  display: displayImageUrl(img, 1400),
  thumb: thumbImageUrl(img),
  srcset: imageSrcSet(img),
}));
const productImages = [data.heroImage, ...data.gallery]
  .filter(Boolean)
  .map((img) => new URL(img, siteUrl).toString());
const categoryBySlug: Record<ProductCategory, { name: string; url: string }> = {
  'slide-on': { name: 'Slide-On Campers', url: '/our-slide-on-campers/' },
  caravan: { name: 'Off-Road Caravans', url: '/our-caravans/' },
  expedition: { name: 'Expedition Vehicles', url: '/expedition/' },
};
const categoryMeta = categoryBySlug[data.category];
const youtubeVideo: YoutubeVideo | undefined = data.youtubeVideo;
const youtubeEmbedParams = new URLSearchParams({
  rel: '0',
  playsinline: '1',
});
if (youtubeVideo?.startSeconds) youtubeEmbedParams.set('start', String(youtubeVideo.startSeconds));
const youtubeEmbedUrl = youtubeVideo
  ? `https://www.youtube-nocookie.com/embed/${youtubeVideo.id}?${youtubeEmbedParams.toString()}`
  : '';
const youtubeWatchUrl = youtubeVideo
  ? `https://www.youtube.com/watch?v=${youtubeVideo.id}${youtubeVideo.startSeconds ? `&t=${youtubeVideo.startSeconds}s` : ''}`
  : '';
const youtubeThumbnail = youtubeVideo?.thumbnail
  ?? (youtubeVideo ? `https://i.ytimg.com/vi/${youtubeVideo.id}/maxresdefault.jpg` : '');
const youtubeUploadDate = normalizeVideoUploadDate(youtubeVideo?.uploadDate);
const activeSpecGroups = data.specGroups?.filter((g: SpecGroup) => g.items.length > 0) ?? [];
const suitability = data.suitabilityData;

function suitabilityValue(value?: string) {
  const trimmed = value?.trim();
  return trimmed || 'Confirm with Beyond RV';
}

function suitabilityStatusLabel(status?: SuitabilityData['status']) {
  if (!status) return 'Confirm with Beyond RV';
  return status.replace(/-/g, ' ').replace(/\b\w/g, (char: string) => char.toUpperCase());
}

const suitabilityFieldRows = data.category === 'caravan'
  ? [
      { label: 'Dry / tare weight', value: suitabilityValue(suitability?.dryWeightKg) },
      { label: 'Estimated loaded weight', value: suitabilityValue(suitability?.estimatedLoadedWeightKg) },
      { label: 'ATM', value: suitabilityValue(suitability?.atmKg) },
      { label: 'GTM', value: suitabilityValue(suitability?.gtmKg) },
      { label: 'Tow ball weight', value: suitabilityValue(suitability?.towBallWeightKg) },
    ]
  : [
      { label: 'Dry weight', value: suitabilityValue(suitability?.dryWeightKg) },
      { label: 'Estimated loaded weight', value: suitabilityValue(suitability?.estimatedLoadedWeightKg) },
      { label: 'Required tray length', value: suitabilityValue(suitability?.requiredTrayLengthMm) },
      { label: 'Required tray width', value: suitabilityValue(suitability?.requiredTrayWidthMm) },
      { label: 'Centre of gravity', value: suitabilityValue(suitability?.centreOfGravityMm) },
    ];

const parsedPrice = parseMoneyValue(data.price);
const hasValidPrice = Number.isFinite(parsedPrice) && parsedPrice > 0;
const configuredDepositPercent = Number.isFinite(paymentSettings.vehicleDepositPercent) && paymentSettings.vehicleDepositPercent > 0 && paymentSettings.vehicleDepositPercent <= 1
  ? paymentSettings.vehicleDepositPercent
  : 1 / 3;
const availability = data.availability ?? (data.status === 'coming-soon' ? 'coming_next_container' : 'available_in_australia');
const isComingSoon = availability !== 'available_in_australia' && availability !== 'made_to_order';
const checkoutOptions = getProductCheckoutOptions({
  price: data.price,
  availability,
  onlinePurchaseEnabled: data.onlinePurchaseEnabled,
  purchasableOnline: data.purchasableOnline,
  depositEnabled: data.depositEnabled,
  fullPaymentEnabled: data.fullPaymentEnabled,
}, configuredDepositPercent, paymentSettings.depositLegalNoticeBody);
const canDeposit = checkoutOptions.supportsDeposit && hasValidPrice;
const canFullPayment = checkoutOptions.supportsFullPrice && hasValidPrice;
const depositAmount = checkoutOptions.depositAmount;
const depositNoticeTitle = paymentSettings.depositLegalNoticeTitle || 'Before you pay a deposit';
const depositNoticeBody = checkoutOptions.legalNoticeText;
const saleBadge = normalizeSaleLabel(data.saleLabel ?? data.priceBadge ?? '');
const availabilityCopy = availability !== 'available_in_australia' ? availabilityLabel(availability) : '';
const sourceCopy = sourceTypeLabel(data.sourceType);
const paymentNote = canDeposit && canFullPayment
  ? 'Secure checkout via Stripe. Deposit and full payment options available.'
  : canDeposit
    ? 'Secure checkout via Stripe. Deposit payment available.'
    : canFullPayment
      ? 'Secure checkout via Stripe. Full payment available.'
      : '';
const productSchema = buildMerchantProduct({
  slug: product.slug,
  name: data.title,
  description: data.seoDesc ?? data.tagline,
  url: productUrl,
  image: productImages,
  price: data.price,
  status: data.status,
  availability: availabilitySchema(availability),
  category: categoryMeta.name,
});

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://beyondrv.com.au/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": categoryMeta.name,
      "item": new URL(categoryMeta.url, siteUrl).toString()
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": data.title,
      "item": productUrl
    }
  ]
};

const faqSchema = data.faq && data.faq.length > 0
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": data.faq.map(({ q, a }: FaqItem) => ({
        "@type": "Question",
        "name": q,
        "acceptedAnswer": { "@type": "Answer", "text": a }
      }))
    }
  : undefined;

const videoSchema = youtubeVideo
  ? {
      "@context": "https://schema.org",
      "@type": "VideoObject",
      "@id": `${productUrl}#video`,
      "name": youtubeVideo.title,
      "description": youtubeVideo.description ?? data.seoDesc ?? data.tagline,
      "thumbnailUrl": youtubeThumbnail,
      "uploadDate": youtubeUploadDate,
      ...(youtubeVideo.duration && { "duration": youtubeVideo.duration }),
      "embedUrl": youtubeEmbedUrl,
      "contentUrl": youtubeWatchUrl,
      "publisher": {
        "@type": "Organization",
        "name": "Beyond RV",
        "logo": {
          "@type": "ImageObject",
          "url": "https://beyondrv.com.au/images/site/admin-logo.png"
        }
      }
    }
  : undefined;

const schemas = [productSchema, breadcrumbSchema, ...(faqSchema ? [faqSchema] : []), ...(videoSchema ? [videoSchema] : [])];
---
<BaseLayout
  title={data.seoTitle ?? `${data.title} | Beyond RV`}
  description={data.seoDesc ?? data.tagline}
  image={data.heroImage}
  type="product"
  canonicalUrl={data.canonicalUrl}
  structuredData={schemas}
  preloadImage={{ src: heroDisplayImage, srcset: heroSrcSet, sizes: heroSizes }}
  activePath={`/${product.slug}/`}
  productTitle={data.title}
  productSlug={product.slug}
>
  <section class="product-hero-section">
    <div class="product-gallery">
      <div class="product-gallery-main">
        <img
          id="productHeroImg"
          src={heroDisplayImage}
          srcset={heroSrcSet}
          sizes={heroSizes}
          alt={data.title}
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
        {galleryImages.length > 1 && (
          <div class="product-gallery-controls" aria-label={`${data.title} gallery navigation`}>
            <button class="gallery-nav-btn gallery-nav-prev" type="button" aria-label="Previous photo" data-gallery-prev>
              ‹
            </button>
            <span class="gallery-count" aria-live="polite">
              <span data-gallery-current>1</span> / {galleryImages.length}
            </span>
            <button class="gallery-nav-btn gallery-nav-next" type="button" aria-label="Next photo" data-gallery-next>
              ›
            </button>
          </div>
        )}
      </div>
      {data.gallery.length > 0 && (
        <div class="product-gallery-thumbs">
          {galleryImages.map((img, i) => (
            <button
              class={`thumb-btn${i === 0 ? ' active' : ''}`}
              data-src={img.display}
              data-srcset={img.srcset}
              aria-label={`View image ${i + 1} of ${data.title}`}
            >
              <img src={img.thumb} alt={`${data.title} — view ${i + 1}`} loading="lazy" decoding="async" />
            </button>
          ))}
        </div>
      )}
    </div>

    <div class="product-hero-info">
      <div class="section-eyebrow">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-text">{data.category}</span>
      </div>
      <h1 class="product-title">{data.title}</h1>
      <p class="product-tagline">{data.tagline}</p>

      <div class="product-price-block">
        {saleBadge && <span class="badge">{saleBadge}</span>}
        {!saleBadge && availabilityCopy && <span class="coming-soon-badge">{availabilityCopy}</span>}
        <div class="product-price-stack">
          {data.compareAtPrice && data.compareAtPrice !== data.price && <span class="product-compare-at">{data.compareAtPrice}</span>}
          <span class="product-price">{data.price}</span>
        </div>
      </div>

      {availabilityCopy && <p class="product-availability-note">{availabilityCopy}</p>}
      {data.leadTimeText && <p class="product-availability-note">{data.leadTimeText}</p>}
      {data.containerEtaText && <p class="product-availability-note">{data.containerEtaText}</p>}
      {data.containerEtaDate && <p class="product-availability-note">ETA date: {data.containerEtaDate}</p>}
      <p class="product-availability-note">{sourceCopy}</p>

      {data.keySpecs.length > 0 && (
        <div class="key-specs">
          {data.keySpecs.map((s: SpecRow) => (
            <div class="key-spec">
              <span class="key-spec-label">{s.label}</span>
              <span class="key-spec-value">{s.value}</span>
            </div>
          ))}
        </div>
      )}

      <div
        class="product-ctas"
        data-stripe-product
        data-product-slug={product.slug}
        data-product-title={data.title}
        data-base-price={parsedPrice}
        data-deposit-percent={configuredDepositPercent}
        data-selected-extra-ids=""
      >
        {canDeposit || canFullPayment ? (
          <>
            {canDeposit && (
              <button type="button" class="btn-primary" data-stripe-checkout data-purchase-type="deposit">
                Buy Now - Deposit {formatShopPrice(depositAmount)}
              </button>
            )}
            {canFullPayment && (
              <button type="button" class="btn-ghost" data-stripe-checkout data-purchase-type="full">
                Buy Now - Full Price {data.price}
              </button>
            )}
            <a href={enquiryUrl} class="btn-ghost">Ask a question</a>
          </>
        ) : (
          <>
            <a href={enquiryUrl + '&intent=register'} class="btn-primary">{availability === 'available_in_australia' ? 'Enquire Now' : 'Register Interest'}</a>
            {availability === 'available_in_australia' && <a href={enquiryUrl + '&intent=buy'} class="btn-ghost">Buy Now</a>}
          </>
        )}
      </div>
      {(canDeposit || canFullPayment) && paymentNote && (
        <p class="product-payment-note" data-payment-note>
          {paymentNote}
        </p>
      )}
      <p class="product-payment-error" data-payment-error role="alert" hidden></p>

      <div class="product-hero-description prose">
        <slot />
        <h2>Is this the right build for you?</h2>
        <p>
          This {data.category === 'caravan' ? 'off-road caravan' : data.category === 'expedition' ? 'expedition camper' : 'slide-on camper'} is best assessed against your vehicle, payload, travel style, and the terrain you expect to cover.
          If you are comparing sizes, tow weights, tray fitment, or custom options, start with the
          <a href={categoryMeta.url}>{categoryMeta.name.toLowerCase()}</a> range or send the team an
          <a href={enquiryUrl}>enquiry for this product</a>.
        </p>
      </div>
    </div>
  </section>

  {(canDeposit || canFullPayment) && (
    <div class="checkout-notice-modal" data-checkout-notice hidden>
      <div class="checkout-notice-backdrop" data-checkout-notice-cancel></div>
      <div class="checkout-notice-card" role="dialog" aria-modal="true" aria-labelledby="checkoutNoticeTitle">
        <div class="section-eyebrow">
          <div class="section-eyebrow-line"></div>
          <span class="section-eyebrow-text">Deposit request</span>
        </div>
        <h2 id="checkoutNoticeTitle">{depositNoticeTitle}</h2>
        <p class="checkout-notice-summary" data-checkout-notice-summary>
          You are about to pay a {formatShopPrice(depositAmount)} deposit for {data.title}.
        </p>
        <ul>
          {depositNoticeBody.map((line: string) => <li>{line}</li>)}
        </ul>
        <div class="checkout-notice-actions">
          <button type="button" class="btn-primary" data-checkout-notice-continue>Continue to secure payment</button>
          <a class="btn-ghost" href={enquiryUrl + '&intent=deposit-question'}>Enquire before paying</a>
          <button type="button" class="checkout-notice-cancel" data-checkout-notice-cancel>Cancel</button>
        </div>
      </div>
    </div>
  )}

  <section class="product-suitability-section container">
    <div class="product-suitability-card">
      <div class="section-eyebrow">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-text">Fitment Guidance</span>
      </div>
      <h2 class="section-title">Weights, Payload &amp; Vehicle Suitability</h2>
      <p class="product-suitability-intro">
        These figures are a buying guide, not a legal guarantee. Confirm your exact vehicle, tray or tow setup,
        accessories, passengers, and loading plan with Beyond RV before purchase.
      </p>

      <div class="product-suitability-status">
        <span class="product-suitability-status-label">Data status</span>
        <strong>{suitabilityStatusLabel(suitability?.status)}</strong>
      </div>

      <div class="product-suitability-grid" aria-label={`${data.title} fitment guidance`}>
        {suitabilityFieldRows.map((row) => (
          <div class="product-suitability-item">
            <span class="product-suitability-label">{row.label}</span>
            <strong class="product-suitability-value">{row.value}</strong>
          </div>
        ))}
      </div>

      {(suitability?.notes ?? data.tagline) && (
        <p class="product-suitability-notes">
          {suitability?.notes ?? data.tagline}
        </p>
      )}
      <p class="product-suitability-disclaimer">
        No invented weights or fitment claims. If a value is missing, it stays as Confirm with Beyond RV.
      </p>
    </div>
  </section>

  {youtubeVideo && (
    <section class="product-video-section container" id="walkthrough-video">
      <div class="section-eyebrow">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-text">Video Walkthrough</span>
      </div>
      <h2 class="section-title">Watch the walkthrough</h2>
      {(youtubeVideo.description || youtubeVideo.transcriptSummary) && (
        <p class="product-video-intro">
          {youtubeVideo.description ?? youtubeVideo.transcriptSummary}
        </p>
      )}
      <div class="product-video-frame">
        <iframe
          src={youtubeEmbedUrl}
          title={youtubeVideo.title}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
      {youtubeVideo.transcriptSummary && youtubeVideo.description && (
        <p class="product-video-summary">{youtubeVideo.transcriptSummary}</p>
      )}
      <div class="product-video-actions">
        <a href={enquiryUrl} class="btn-primary">Enquire About This Build</a>
      </div>
    </section>
  )}

  {activeSpecGroups.length > 0 && (
    <section class="product-specs-section container">
      <div class="specs-heading-row">
        <div>
          <div class="section-eyebrow">
            <div class="section-eyebrow-line"></div>
            <span class="section-eyebrow-text">Product Details</span>
          </div>
          <h2 class="section-title">Specifications</h2>
        </div>
        <div class="specs-actions" aria-label="Specification section controls">
          <button class="specs-toggle-btn" type="button" data-specs-expand>Expand all</button>
          <button class="specs-toggle-btn" type="button" data-specs-collapse>Collapse all</button>
        </div>
      </div>

      {data.keySpecs.length > 0 && (
        <div class="specs-summary-strip" aria-label={`${data.title} key specifications`}>
          {data.keySpecs.map((s: SpecRow) => (
            <div class="specs-summary-item">
              <span class="specs-summary-label">{s.label}</span>
              <span class="specs-summary-value">{s.value}</span>
            </div>
          ))}
        </div>
      )}

      <div class="spec-accordion">
        {activeSpecGroups.map((group: SpecGroup, index: number) => (
          <details class="spec-panel" open={index < 2}>
            <summary class="spec-panel-summary">
              <span>{group.group}</span>
              <span class="spec-panel-count">{group.items.length} specs</span>
            </summary>
            <dl class="spec-list">
              {group.items.map((row: SpecRow) => (
                <div class="spec-list-row">
                  <dt>{row.label}</dt>
                  <dd>{row.value}</dd>
                </div>
              ))}
            </dl>
          </details>
        ))}
      </div>
    </section>
  )}

  {(!data.specGroups || data.specGroups.length === 0) && data.specs && data.specs.length > 0 && (
    <section class="product-specs-section container">
      <div class="specs-heading-row">
        <div>
          <div class="section-eyebrow">
            <div class="section-eyebrow-line"></div>
            <span class="section-eyebrow-text">Product Details</span>
          </div>
          <h2 class="section-title">Specifications</h2>
        </div>
      </div>
      <div class="spec-accordion">
        <details class="spec-panel" open>
          <summary class="spec-panel-summary">
            <span>Full Specifications</span>
            <span class="spec-panel-count">{data.specs.length} specs</span>
          </summary>
          <dl class="spec-list">
          {data.specs.map((row: SpecRow) => (
            <div class="spec-list-row">
              <dt>{row.label}</dt>
              <dd>{row.value}</dd>
            </div>
          ))}
          </dl>
        </details>
      </div>
    </section>
  )}

  {!isComingSoon && (
    <OptionalExtras
      client:load
      basePrice={data.price}
      productSlug={product.slug}
      productName={data.title}
    />
  )}

  {data.features && data.features.length > 0 && (
    <section class="product-features-section container">
      <h2 class="section-title">Features</h2>
      <ul class="features-list">
        {data.features.map((f: Feature) => <li>{f}</li>)}
      </ul>
    </section>
  )}

  {data.faq && data.faq.length > 0 && (
    <section class="product-faq-section container">
      <h2 class="section-title">FAQ</h2>
      <div class="faq-list">
        {data.faq.map(({ q, a }: FaqItem, i: number) => (
          <div class="faq-item" id={`faq-${i}`}>
            <button class="faq-question" aria-expanded="false" aria-controls={`faq-answer-${i}`}>
              {q}
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer" id={`faq-answer-${i}`} role="region">
              <p>{a}</p>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="product-enquiry-band">
    <div class="container">
      <h2>Ready to make it yours?</h2>
      <p>
        Talk to the team — we're based in Mutdapilly, QLD, and we build every camper ourselves.
      </p>
      <div class="product-ctas">
        {isComingSoon ? (
          <a href={enquiryUrl + '&intent=register'} class="btn-primary">Register Interest</a>
        ) : (
          <>
            <a href={enquiryUrl} class="btn-primary">Enquire Now</a>
            <a href="tel:+61430863819" class="btn-ghost">Call 0430 863 819</a>
          </>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const heroImg = document.getElementById('productHeroImg') as HTMLImageElement | null;
  const thumbButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.thumb-btn'));
  const galleryCurrent = document.querySelector<HTMLElement>('[data-gallery-current]');
const checkoutRoot = document.querySelector<HTMLElement>('[data-stripe-product]');
const checkoutError = document.querySelector<HTMLElement>('[data-payment-error]');
const noticeModal = document.querySelector<HTMLElement>('[data-checkout-notice]');
const noticeSummary = document.querySelector<HTMLElement>('[data-checkout-notice-summary]');
const noticeContinue = document.querySelector<HTMLButtonElement>('[data-checkout-notice-continue]');
const noticeCancelButtons = document.querySelectorAll<HTMLElement>('[data-checkout-notice-cancel]');
const paymentNoteEl = document.querySelector<HTMLElement>('[data-payment-note]');
const depositCheckoutButton = checkoutRoot?.querySelector<HTMLButtonElement>('[data-stripe-checkout][data-purchase-type="deposit"]');
const fullCheckoutButton = checkoutRoot?.querySelector<HTMLButtonElement>('[data-stripe-checkout][data-purchase-type="full"]');
const defaultPaymentNote = paymentNoteEl?.textContent?.trim() || 'Secure checkout via Stripe.';
let pendingCheckoutButton: HTMLButtonElement | null = null;
let selectedExtraIds: string[] = [];

function formatCheckoutMoney(amount: number, includeCents = true) {
  if (!Number.isFinite(amount)) return includeCents ? '$0.00' : '$0';
  return amount.toLocaleString('en-AU', {
    style: 'currency',
    currency: 'AUD',
    minimumFractionDigits: includeCents ? 2 : 0,
    maximumFractionDigits: includeCents ? 2 : 0,
  });
}

function configuredCheckoutTotal() {
  const configured = Number(checkoutRoot?.dataset.configuredTotal);
  const base = Number(checkoutRoot?.dataset.basePrice);
  return Number.isFinite(configured) && configured > 0 ? configured : base;
}

function configuredDepositAmount() {
  const total = configuredCheckoutTotal();
  const percent = Number(checkoutRoot?.dataset.depositPercent);
  const depositPercent = Number.isFinite(percent) && percent > 0 && percent <= 1 ? percent : 1 / 3;
  return Math.max(1, Math.round(total * depositPercent));
}

function selectedExtraIdsFromRoot() {
  return (checkoutRoot?.dataset.selectedExtraIds ?? '')
    .split(',')
    .map((id) => id.trim())
    .filter(Boolean);
}

function updateConfiguredCheckoutText() {
  selectedExtraIds = selectedExtraIdsFromRoot();
  const total = configuredCheckoutTotal();
  const hasExtras = selectedExtraIds.length > 0;
  if (depositCheckoutButton) {
    depositCheckoutButton.textContent = `Buy Now - Deposit ${formatCheckoutMoney(configuredDepositAmount())}`;
  }
  if (fullCheckoutButton) {
    fullCheckoutButton.textContent = `Buy Now - Full Price ${formatCheckoutMoney(total, false)}`;
  }
  if (paymentNoteEl) {
    paymentNoteEl.textContent = hasExtras
      ? `Secure checkout via Stripe. Payment is based on your configured total of ${formatCheckoutMoney(total, false)}, including selected extras.`
      : defaultPaymentNote;
  }
}

window.addEventListener('byondrv:extras-change', () => {
  updateConfiguredCheckoutText();
});

  function openCheckoutNotice(button: HTMLButtonElement) {
    if (!noticeModal) return false;
    pendingCheckoutButton = button;
    const purchaseType = button.dataset.purchaseType;
    if (noticeSummary) {
      const productTitle = checkoutRoot?.dataset.productTitle || 'this product';
      noticeSummary.textContent = purchaseType === 'deposit'
        ? `You are about to pay a ${formatCheckoutMoney(configuredDepositAmount())} deposit for ${productTitle}, based on the configured total of ${formatCheckoutMoney(configuredCheckoutTotal(), false)}.`
        : `You are about to pay the configured total of ${formatCheckoutMoney(configuredCheckoutTotal(), false)} for ${productTitle}.`;
    }
    noticeModal.hidden = false;
    document.body.style.overflow = 'hidden';
    noticeContinue?.focus();
    return true;
  }

  function closeCheckoutNotice() {
    if (!noticeModal) return;
    noticeModal.hidden = true;
    document.body.style.overflow = '';
  }

  noticeCancelButtons.forEach(button => {
    button.addEventListener('click', () => {
      pendingCheckoutButton = null;
      closeCheckoutNotice();
    });
  });

  noticeContinue?.addEventListener('click', () => {
    const button = pendingCheckoutButton;
    pendingCheckoutButton = null;
    closeCheckoutNotice();
    if (button) void startStripeCheckout(button);
  });
  let activeGalleryIndex = Math.max(0, thumbButtons.findIndex(btn => btn.classList.contains('active')));

  function showGalleryImage(index: number) {
    if (!heroImg || thumbButtons.length === 0) return;

    const nextIndex = (index + thumbButtons.length) % thumbButtons.length;
    const nextButton = thumbButtons[nextIndex];
    if (!nextButton?.dataset.src) return;

    heroImg.src = nextButton.dataset.src;
    if (nextButton.dataset.srcset) heroImg.srcset = nextButton.dataset.srcset;

    thumbButtons.forEach(btn => btn.classList.remove('active'));
    nextButton.classList.add('active');
    activeGalleryIndex = nextIndex;
    if (galleryCurrent) galleryCurrent.textContent = String(nextIndex + 1);
  }

  thumbButtons.forEach((btn, index) => {
    btn.addEventListener('click', () => showGalleryImage(index));
  });

  document.querySelector<HTMLButtonElement>('[data-gallery-prev]')?.addEventListener('click', () => {
    showGalleryImage(activeGalleryIndex - 1);
  });

  document.querySelector<HTMLButtonElement>('[data-gallery-next]')?.addEventListener('click', () => {
    showGalleryImage(activeGalleryIndex + 1);
  });

  document.querySelector<HTMLElement>('.product-gallery-main')?.addEventListener('keydown', event => {
    if (event.key === 'ArrowLeft') showGalleryImage(activeGalleryIndex - 1);
    if (event.key === 'ArrowRight') showGalleryImage(activeGalleryIndex + 1);
  });

  document.querySelectorAll<HTMLButtonElement>('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const isOpen = item?.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(el => {
        el.classList.remove('open');
        el.querySelector<HTMLButtonElement>('.faq-question')?.setAttribute('aria-expanded', 'false');
      });
      if (!isOpen && item) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  const specPanels = Array.from(document.querySelectorAll<HTMLDetailsElement>('.spec-panel'));
  document.querySelector<HTMLButtonElement>('[data-specs-expand]')?.addEventListener('click', () => {
    specPanels.forEach(panel => {
      panel.open = true;
    });
  });
  document.querySelector<HTMLButtonElement>('[data-specs-collapse]')?.addEventListener('click', () => {
    specPanels.forEach(panel => {
      panel.open = false;
    });
  });

  async function startStripeCheckout(button: HTMLButtonElement) {
    if (!checkoutRoot) return;
    const slug = checkoutRoot.dataset.productSlug;
    const purchaseType = button.dataset.purchaseType;
    if (!slug || (purchaseType !== 'deposit' && purchaseType !== 'full')) return;

    const originalLabel = button.textContent ?? 'Checkout';
    button.disabled = true;
    button.textContent = 'Starting secure checkout...';
    if (checkoutError) checkoutError.hidden = true;

    try {
      const response = await fetch('/api/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug, type: purchaseType, selectedExtraIds }),
      });
      const data = await response.json().catch(() => ({}));

      if (response.ok && data && typeof data.url === 'string') {
        window.location.href = data.url;
        return;
      }

      if (checkoutError) {
        checkoutError.textContent = (data && data.message) || 'Something went wrong creating your checkout. Please try again or call 0430 863 819.';
        checkoutError.hidden = false;
      }
    } catch {
      if (checkoutError) {
        checkoutError.textContent = 'Something went wrong creating your checkout. Please try again or call 0430 863 819.';
        checkoutError.hidden = false;
      }
    }

    button.disabled = false;
    button.textContent = originalLabel;
  }

  checkoutRoot?.addEventListener('click', (event) => {
    const button = (event.target as HTMLElement).closest<HTMLButtonElement>('[data-stripe-checkout]');
    if (!button) return;

    const slug = checkoutRoot.dataset.productSlug;
    const purchaseType = button.dataset.purchaseType;
    if (!slug || (purchaseType !== 'deposit' && purchaseType !== 'full')) return;

    if (!openCheckoutNotice(button)) void startStripeCheckout(button);
  });

  updateConfiguredCheckoutText();
</script>
